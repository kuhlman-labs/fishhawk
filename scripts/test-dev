#!/usr/bin/env zsh
# Hermetic unit test for scripts/dev library helpers.
# Sources scripts/dev with DEV_LIB_ONLY=1 (dispatch suppressed) and asserts the
# MCP-activation signalling and cmd_reload wiring without starting the stack.
# Must be zsh: scripts/dev uses zsh-only features (typeset -A, subscript flags).
# Standalone like scripts/test-cleanup-merged — not wired into scripts/test or CI.
set -uo pipefail

REPO_ROOT="${0:A:h:h}"
PASS=0
FAIL=0

pass() { print "PASS: $1"; PASS=$(( PASS + 1 )) }
fail() { print "FAIL: $1"; FAIL=$(( FAIL + 1 )) }

# Source the library. scripts/dev enables `set -e`; turn it back off so the
# assertions below (which run commands expected to fail) don't abort the test.
DEV_LIB_ONLY=1 source "${REPO_ROOT}/scripts/dev"
set +e

# 1. Rebuilt path: prominent, names the binary, and tells the operator to reconnect.
out="$(_signal_mcp_activation 1)"
if [[ "$out" == *fishhawk-mcp* ]]; then
  pass "rebuilt signal mentions fishhawk-mcp"
else
  fail "rebuilt signal should mention fishhawk-mcp (got: $out)"
fi
if print -r -- "$out" | grep -qi reconnect; then
  pass "rebuilt signal matches /reconnect/i"
else
  fail "rebuilt signal should match /reconnect/i (got: $out)"
fi

# 2. Unchanged path: single explicit no-op line.
out="$(_signal_mcp_activation 0)"
if [[ "$out" == *"no MCP reconnect needed"* ]]; then
  pass "unchanged signal says 'no MCP reconnect needed'"
else
  fail "unchanged signal should say 'no MCP reconnect needed' (got: $out)"
fi

# 3. cmd_reload core behavior: invokes cmd_down then cmd_up, forwarding flags.
reload_body="$(typeset -f cmd_reload)"
if print -r -- "$reload_body" | grep -q cmd_down; then
  pass "cmd_reload invokes cmd_down"
else
  fail "cmd_reload should invoke cmd_down"
fi
if print -r -- "$reload_body" | grep -q cmd_up; then
  pass "cmd_reload invokes cmd_up"
else
  fail "cmd_reload should invoke cmd_up"
fi
if print -r -- "$reload_body" | grep -q '"\$@"'; then
  pass "cmd_reload forwards flags (\"\$@\") to cmd_up"
else
  fail "cmd_reload should forward \"\$@\" to cmd_up"
fi
# reload must force a full rebuild (--all) so the empty post-merge
# origin/main...HEAD diff doesn't silently skip runner/CLI/mcp.
if print -r -- "$reload_body" | grep -q -- '--all'; then
  pass "cmd_reload forces a full rebuild (--all)"
else
  fail "cmd_reload should force --all"
fi

# 3b. cmd_post_merge wiring: ff-only pull, cleanup-merged, optional issue check,
# then reload LAST. Body-grep only (mirrors section 3) — a live post-merge mutates
# git state and the running stack and is not hermetic.
post_body="$(typeset -f cmd_post_merge)"
if print -r -- "$post_body" | grep -q -- '--ff-only'; then
  pass "cmd_post_merge pulls main with --ff-only"
else
  fail "cmd_post_merge should pull --ff-only"
fi
if print -r -- "$post_body" | grep -q 'cleanup-merged'; then
  pass "cmd_post_merge invokes scripts/cleanup-merged"
else
  fail "cmd_post_merge should invoke cleanup-merged"
fi
if print -r -- "$post_body" | grep -q 'gh issue view'; then
  pass "cmd_post_merge confirms the optional issue via gh issue view"
else
  fail "cmd_post_merge should reference gh issue view"
fi
if print -r -- "$post_body" | grep -q 'cmd_reload'; then
  pass "cmd_post_merge composes cmd_reload"
else
  fail "cmd_post_merge should invoke cmd_reload"
fi

# 4. _diff_touches_mcp: pure matcher mirrors the rebuild matrix's mcp routing.
if _diff_touches_mcp "backend/cmd/fishhawk-mcp/main.go"; then
  pass "_diff_touches_mcp matches backend/cmd/fishhawk-mcp/"
else
  fail "_diff_touches_mcp should match backend/cmd/fishhawk-mcp/"
fi
if _diff_touches_mcp "backend/internal/plan/validate.go"; then
  pass "_diff_touches_mcp matches shared lib backend/internal/plan/"
else
  fail "_diff_touches_mcp should match backend/internal/plan/"
fi
if _diff_touches_mcp "backend/internal/spec/load.go"; then
  pass "_diff_touches_mcp matches shared lib backend/internal/spec/"
else
  fail "_diff_touches_mcp should match backend/internal/spec/"
fi
# #612 case: --all rebuilt mcp, but the merge delta touched only runner source.
if _diff_touches_mcp "runner/internal/plan/coerce.go"; then
  fail "_diff_touches_mcp should NOT match runner-only delta"
else
  pass "_diff_touches_mcp stays quiet for runner-only delta"
fi

# 5. _decide_mcp_signal: all three branches plus the reflog-unavailable fallback.
# Args: <mcp_rebuilt> <force_all> <reflog_ok> <merge_diff_text>
if [[ "$(_decide_mcp_signal 0 1 1 'backend/cmd/fishhawk-mcp/main.go')" == 0 ]]; then
  pass "_decide_mcp_signal: mcp not rebuilt -> 0"
else
  fail "_decide_mcp_signal: mcp not rebuilt should be 0"
fi
if [[ "$(_decide_mcp_signal 1 1 1 'backend/cmd/fishhawk-mcp/main.go')" == 1 ]]; then
  pass "_decide_mcp_signal: rebuilt + --all + diff touches mcp -> 1"
else
  fail "_decide_mcp_signal: rebuilt + --all + mcp delta should be 1"
fi
if [[ "$(_decide_mcp_signal 1 1 1 'runner/internal/plan/coerce.go')" == 0 ]]; then
  pass "_decide_mcp_signal: rebuilt + --all + diff misses mcp -> 0"
else
  fail "_decide_mcp_signal: rebuilt + --all + non-mcp delta should be 0"
fi
if [[ "$(_decide_mcp_signal 1 1 0 '')" == 1 ]]; then
  pass "_decide_mcp_signal: rebuilt + --all + no reflog -> 1 (fallback)"
else
  fail "_decide_mcp_signal: reflog-unavailable fallback should be 1"
fi
if [[ "$(_decide_mcp_signal 1 0 1 'runner/internal/plan/coerce.go')" == 1 ]]; then
  pass "_decide_mcp_signal: rebuilt under branch-diff up -> 1"
else
  fail "_decide_mcp_signal: branch-diff up rebuild should be 1"
fi

# 7. _healthz_url: derives the port from FISHHAWKD_ADDR, default 8080.
unset FISHHAWKD_ADDR
if [[ "$(_healthz_url)" == "http://localhost:8080/healthz" ]]; then
  pass "_healthz_url defaults to port 8080 when FISHHAWKD_ADDR unset"
else
  fail "_healthz_url should default to 8080 (got: $(_healthz_url))"
fi
FISHHAWKD_ADDR=':9090'
if [[ "$(_healthz_url)" == "http://localhost:9090/healthz" ]]; then
  pass "_healthz_url respects ':9090' override"
else
  fail "_healthz_url should use port 9090 for ':9090' (got: $(_healthz_url))"
fi
FISHHAWKD_ADDR='127.0.0.1:9091'
if [[ "$(_healthz_url)" == "http://localhost:9091/healthz" ]]; then
  pass "_healthz_url respects '127.0.0.1:9091' override"
else
  fail "_healthz_url should use port 9091 for '127.0.0.1:9091' (got: $(_healthz_url))"
fi
unset FISHHAWKD_ADDR

# 8. _await_healthz: returns non-zero quickly for an already-exited pid (the
# spawn-then-die early-exit path) without needing a live server.
( exit 0 ) &
dead_pid=$!
wait "$dead_pid" 2>/dev/null
if _await_healthz "$dead_pid" "http://localhost:1/healthz" 10; then
  fail "_await_healthz should return non-zero for an already-exited pid"
else
  pass "_await_healthz returns non-zero promptly for a dead pid"
fi

# 9. cmd_up readiness gate: body must poll _await_healthz, tail the log, and
# exit 1 on failure — mirroring the existing cmd_reload body-grep assertions.
up_body="$(typeset -f cmd_up)"
if print -r -- "$up_body" | grep -q '_await_healthz'; then
  pass "cmd_up gates the spawn on _await_healthz"
else
  fail "cmd_up should call _await_healthz after spawning fishhawkd"
fi
if print -r -- "$up_body" | grep -q 'tail -n 15'; then
  pass "cmd_up tails the log on a failed readiness gate"
else
  fail "cmd_up should tail the log on readiness-gate failure"
fi
if print -r -- "$up_body" | grep -q 'exit 1'; then
  pass "cmd_up exits non-zero on a failed readiness gate"
else
  fail "cmd_up should exit 1 on readiness-gate failure"
fi

# 10. ZERR diagnostic trap (#631): installed, reports the ERROR-SITE file:line
# (not the trap's own body line), propagates the exit code, and the hardening
# can't silently regress.
if (( ${+functions[TRAPZERR]} )); then
  pass "TRAPZERR diagnostic trap is installed"
else
  fail "TRAPZERR should be defined/installed as the ZERR trap"
fi
# Sourcing scripts/dev installed TRAPZERR into THIS test process; neutralize it
# here so its stderr doesn't pollute the test's own output (the assertions below
# intentionally drive a fixture subprocess that exits non-zero, and the harness
# itself exits non-zero on failure). The fixture re-sources scripts/dev, so it
# exercises the real trap in isolation.
unfunction TRAPZERR 2>/dev/null
trap - ZERR

# Error-site precision: a fixture that fails on a KNOWN line (line 5) must be
# named by the diagnostic. Sources the real scripts/dev so the actual TRAPZERR
# fires; funcfiletrace[1] must point at the fixture's failing line, not the trap
# body's line inside scripts/dev.
zerr_fixture="$(mktemp -t test-dev-zerr.XXXXXX)"
cat > "$zerr_fixture" <<EOF
#!/usr/bin/env zsh
set -euo pipefail
DEV_LIB_ONLY=1 source "${REPO_ROOT}/scripts/dev"
true
( exit 7 )
EOF
zerr_out="$(zsh "$zerr_fixture" 2>&1 1>/dev/null)"
zerr_rc=$?
rm -f "$zerr_fixture"
if (( zerr_rc == 7 )); then
  pass "ZERR abort propagates the failing exit code (7), never zero-output exit 0"
else
  fail "fixture should exit 7 under set -e (got rc=$zerr_rc)"
fi
if [[ "$zerr_out" == *"exit 7"* ]]; then
  pass "TRAPZERR reports the failing command's exit code (exit 7)"
else
  fail "TRAPZERR should report 'exit 7' (got: $zerr_out)"
fi
if [[ "$zerr_out" == *line* ]]; then
  pass "TRAPZERR diagnostic includes 'line'"
else
  fail "TRAPZERR diagnostic should include 'line' (got: $zerr_out)"
fi
if [[ "$zerr_out" == *:5* ]]; then
  pass "TRAPZERR names the error-site line (fixture line 5)"
else
  fail "TRAPZERR should name the failing line :5 (got: $zerr_out)"
fi
if [[ "$zerr_out" == */scripts/dev:* ]]; then
  fail "TRAPZERR named scripts/dev — should report the error site, not its own trap line (got: $zerr_out)"
else
  pass "TRAPZERR reports the error site, not the trap's internal scripts/dev line"
fi

# Hardening guard: no fragile `]] && <var>=` assignment-RHS pattern may remain in
# scripts/dev — that bare-&&-in-a-non-tested-context form is the ERR_EXIT hazard
# this change removed, and it must not silently creep back.
if grep -nE '\]\] &&[[:space:]]+[A-Za-z_][A-Za-z0-9_]*(\[[^]]*\])?=' "${REPO_ROOT}/scripts/dev"; then
  fail "scripts/dev still has a fragile ']] && var=' assignment (ERR_EXIT hazard)"
else
  pass "no fragile ']] && var=' assignment remains in scripts/dev"
fi

# The confirmed #631 trigger: `(( i++ ))` returns exit 1 when i==0 (post-increment
# yields the old value, and (( 0 )) is false), aborting the loop body under set -e.
# Guard that no post-increment arithmetic counter survives in scripts/dev.
if grep -nE '\(\([[:space:]]*[A-Za-z_][A-Za-z0-9_]*\+\+[[:space:]]*\)\)' "${REPO_ROOT}/scripts/dev"; then
  fail "scripts/dev still has a '(( var++ ))' post-increment (set -e abort at var==0, #631)"
else
  pass "no fragile '(( var++ ))' post-increment remains in scripts/dev"
fi

# The replacement `(( ++i ))` counter loop is ERR_EXIT-safe from i==0: the body
# must run and the loop complete without aborting under set -e.
if ( set -e; i=0; while (( i < 2 )); do (( ++i )); done; print "$i" ) >/dev/null 2>&1; then
  pass "'(( ++i ))' counter loop from i==0 does not abort under set -e"
else
  fail "'(( ++i ))' counter loop aborted under set -e (the #631 regression)"
fi

# The rewritten `if [[ false-cond ]]; then var=1; fi` form is ERR_EXIT-safe: a
# false condition must NOT abort under set -e (the `[[ ]]` is the if-condition, a
# tested context). zsh's ERR_EXIT-vs-`&&` interaction is subtle and version-
# dependent — the explicit if-form removes that ambiguity entirely, which is the
# point of the hardening.
if ( set -e; v=0; if [[ 1 == 2 ]]; then v=1; fi; print "$v" ) >/dev/null 2>&1; then
  pass "rewritten 'if [[ false ]]; then var=1; fi' does not abort under set -e"
else
  fail "rewritten if-form aborted under set -e (a false condition should be safe)"
fi

# 6. Parse check: scripts/dev is valid zsh.
if zsh -n "${REPO_ROOT}/scripts/dev"; then
  pass "scripts/dev parses clean (zsh -n)"
else
  fail "scripts/dev failed zsh -n parse check"
fi

print ""
print "Results: ${PASS} passed, ${FAIL} failed"
[[ "$FAIL" -eq 0 ]]
