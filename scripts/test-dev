#!/usr/bin/env zsh
# Hermetic unit test for scripts/dev library helpers.
# Sources scripts/dev with DEV_LIB_ONLY=1 (dispatch suppressed) and asserts the
# MCP-activation signalling and cmd_reload wiring without starting the stack.
# Must be zsh: scripts/dev uses zsh-only features (typeset -A, subscript flags).
# Standalone like scripts/test-cleanup-merged — not wired into scripts/test or CI.
set -uo pipefail

REPO_ROOT="${0:A:h:h}"
PASS=0
FAIL=0

pass() { print "PASS: $1"; PASS=$(( PASS + 1 )) }
fail() { print "FAIL: $1"; FAIL=$(( FAIL + 1 )) }

# Source the library. scripts/dev enables `set -e`; turn it back off so the
# assertions below (which run commands expected to fail) don't abort the test.
DEV_LIB_ONLY=1 source "${REPO_ROOT}/scripts/dev"
set +e

# 1. _signal_mcp_activation is now KIND-form (ADR-060 / #1922): one banner per
# kind (schema_major | shim_rebuilt | reconnect | auto_swap | none). Assert the
# shipped text of each, not mere helper presence.
out="$(_signal_mcp_activation schema_major)"
if print -r -- "$out" | grep -q 'schema MAJOR'; then
  pass "schema_major banner names the schema MAJOR bump"
else
  fail "schema_major banner should name the schema MAJOR bump (got: $out)"
fi

out="$(_signal_mcp_activation shim_rebuilt)"
if [[ "$out" == *fishhawk-mcp-shim* ]] && print -r -- "$out" | grep -q -- '/mcp'; then
  pass "shim_rebuilt banner names fishhawk-mcp-shim and /mcp"
else
  fail "shim_rebuilt banner should name fishhawk-mcp-shim and /mcp (got: $out)"
fi

out="$(_signal_mcp_activation reconnect)"
if [[ "$out" == *fishhawk-mcp* ]] && print -r -- "$out" | grep -qi reconnect \
   && print -r -- "$out" | grep -q 'ACTION REQUIRED'; then
  pass "reconnect banner keeps the ACTION REQUIRED fishhawk-mcp reconnect text"
else
  fail "reconnect banner should keep the ACTION REQUIRED fishhawk-mcp reconnect text (got: $out)"
fi

# auto_swap: a single line naming automatic swap + GitSHA verification, and it
# must NOT carry the manual ACTION REQUIRED nag (the shim swaps automatically).
out="$(_signal_mcp_activation auto_swap)"
if print -r -- "$out" | grep -qi 'hot-swaps' && print -r -- "$out" | grep -q 'GitSHA' \
   && ! print -r -- "$out" | grep -q 'ACTION REQUIRED'; then
  pass "auto_swap note names automatic swap + GitSHA and omits ACTION REQUIRED"
else
  fail "auto_swap note should name automatic swap + GitSHA and omit ACTION REQUIRED (got: $out)"
fi
if [[ "$(print -r -- "$out" | grep -c .)" == 1 ]]; then
  pass "auto_swap note is a single line"
else
  fail "auto_swap note should be a single line (got: $out)"
fi

# 2. Unchanged path (none): single explicit no-op line.
out="$(_signal_mcp_activation none)"
if [[ "$out" == *"no MCP reconnect needed"* ]]; then
  pass "none banner says 'no MCP reconnect needed'"
else
  fail "none banner should say 'no MCP reconnect needed' (got: $out)"
fi
# Unknown/absent kind degrades to the no-op line.
out="$(_signal_mcp_activation)"
if [[ "$out" == *"no MCP reconnect needed"* ]]; then
  pass "absent kind degrades to 'no MCP reconnect needed'"
else
  fail "absent kind should degrade to 'no MCP reconnect needed' (got: $out)"
fi

# 3. cmd_reload core behavior: invokes cmd_down then cmd_up, forwarding flags.
reload_body="$(typeset -f cmd_reload)"
if print -r -- "$reload_body" | grep -q cmd_down; then
  pass "cmd_reload invokes cmd_down"
else
  fail "cmd_reload should invoke cmd_down"
fi
if print -r -- "$reload_body" | grep -q cmd_up; then
  pass "cmd_reload invokes cmd_up"
else
  fail "cmd_reload should invoke cmd_up"
fi
if print -r -- "$reload_body" | grep -q '"\$@"'; then
  pass "cmd_reload forwards flags (\"\$@\") to cmd_up"
else
  fail "cmd_reload should forward \"\$@\" to cmd_up"
fi
# reload must force a full rebuild (--all) so the empty post-merge
# origin/main...HEAD diff doesn't silently skip runner/CLI/mcp.
if print -r -- "$reload_body" | grep -q -- '--all'; then
  pass "cmd_reload forces a full rebuild (--all)"
else
  fail "cmd_reload should force --all"
fi

# 3b. cmd_post_merge wiring: ff-only pull, cleanup-merged, optional issue check,
# then reload LAST. Body-grep only (mirrors section 3) — a live post-merge mutates
# git state and the running stack and is not hermetic.
post_body="$(typeset -f cmd_post_merge)"
if print -r -- "$post_body" | grep -q -- '--ff-only'; then
  pass "cmd_post_merge pulls main with --ff-only"
else
  fail "cmd_post_merge should pull --ff-only"
fi
if print -r -- "$post_body" | grep -q 'cleanup-merged'; then
  pass "cmd_post_merge invokes scripts/cleanup-merged"
else
  fail "cmd_post_merge should invoke cleanup-merged"
fi
if print -r -- "$post_body" | grep -q 'gh issue view'; then
  pass "cmd_post_merge confirms the optional issue via gh issue view"
else
  fail "cmd_post_merge should reference gh issue view"
fi
if print -r -- "$post_body" | grep -q 'cmd_reload'; then
  pass "cmd_post_merge composes cmd_reload"
else
  fail "cmd_post_merge should invoke cmd_reload"
fi

# 4. _diff_touches_mcp: pure matcher mirrors the rebuild matrix's mcp routing.
if _diff_touches_mcp "backend/cmd/fishhawk-mcp/main.go"; then
  pass "_diff_touches_mcp matches backend/cmd/fishhawk-mcp/"
else
  fail "_diff_touches_mcp should match backend/cmd/fishhawk-mcp/"
fi
if _diff_touches_mcp "backend/internal/plan/validate.go"; then
  pass "_diff_touches_mcp matches shared lib backend/internal/plan/"
else
  fail "_diff_touches_mcp should match backend/internal/plan/"
fi
if _diff_touches_mcp "backend/internal/spec/load.go"; then
  pass "_diff_touches_mcp matches shared lib backend/internal/spec/"
else
  fail "_diff_touches_mcp should match backend/internal/spec/"
fi
# #612 case: --all rebuilt mcp, but the merge delta touched only runner source.
if _diff_touches_mcp "runner/internal/plan/coerce.go"; then
  fail "_diff_touches_mcp should NOT match runner-only delta"
else
  pass "_diff_touches_mcp stays quiet for runner-only delta"
fi
# Cross-glob non-collision (ADR-060 / #1922): the mcp glob must NOT match a shim
# path — the literal `/` after `fishhawk-mcp` blocks the prefix.
if _diff_touches_mcp "backend/cmd/fishhawk-mcp-shim/main.go"; then
  fail "_diff_touches_mcp should NOT match a fishhawk-mcp-shim path"
else
  pass "_diff_touches_mcp stays quiet for a fishhawk-mcp-shim path (cross-glob non-collision)"
fi

# 4a. _diff_touches_shim: the shim's OWN trigger glob only — not the shared libs,
# and (cross-glob non-collision) not a plain fishhawk-mcp path.
if _diff_touches_shim "backend/cmd/fishhawk-mcp-shim/main.go"; then
  pass "_diff_touches_shim matches backend/cmd/fishhawk-mcp-shim/"
else
  fail "_diff_touches_shim should match backend/cmd/fishhawk-mcp-shim/"
fi
if _diff_touches_shim "backend/cmd/fishhawk-mcp/main.go"; then
  fail "_diff_touches_shim should NOT match a plain fishhawk-mcp path"
else
  pass "_diff_touches_shim stays quiet for a fishhawk-mcp path (cross-glob non-collision)"
fi
# The shim deliberately does NOT join the shared-lib case.
if _diff_touches_shim "backend/internal/plan/validate.go"; then
  fail "_diff_touches_shim should NOT match a shared-lib path"
else
  pass "_diff_touches_shim stays quiet for a shared-lib path (shim not in the shared-lib case)"
fi

# 4b. _sha_with_dirty: pure dirty-suffix helper (#1007). Empty porcelain text
# means a clean tree -> bare sha; any output means dirty -> '-dirty' suffix.
out="$(_sha_with_dirty abc1234 "")"
if [[ "$out" == "abc1234" ]]; then
  pass "_sha_with_dirty leaves a clean-tree sha bare"
else
  fail "_sha_with_dirty should leave a clean-tree sha bare (got: $out)"
fi
out="$(_sha_with_dirty abc1234 " M scripts/dev")"
if [[ "$out" == "abc1234-dirty" ]]; then
  pass "_sha_with_dirty appends -dirty for non-empty porcelain"
else
  fail "_sha_with_dirty should append -dirty (got: $out)"
fi

# 4c. _build_ldflags: each binary stamps GitSHA into the right version package,
# AND that package actually declares `var GitSHA` — load-bearing: -ldflags -X
# on a package path without the var is a SILENT no-op, not a build error, so a
# package move/rename must fail here instead of shipping unstamped binaries.
typeset -A gitsha_pkg
gitsha_pkg=(
  fishhawkd         backend/internal/version
  fishhawk-mcp      backend/internal/version
  fishhawk-mcp-shim backend/internal/version
  fishhawk-runner   runner/internal/version
  fishhawk          cli/internal/version
)
for bin in fishhawkd fishhawk-mcp fishhawk-mcp-shim fishhawk-runner fishhawk; do
  rel="${gitsha_pkg[$bin]}"
  out="$(_build_ldflags "$bin" abc1234)"
  if [[ "$out" == "-X github.com/kuhlman-labs/fishhawk/${rel}.GitSHA=abc1234" ]]; then
    pass "_build_ldflags ${bin} -> ${rel}.GitSHA"
  else
    fail "_build_ldflags ${bin} should stamp ${rel}.GitSHA (got: $out)"
  fi
  if grep -q '^var GitSHA' "${REPO_ROOT}/${rel}/version.go"; then
    pass "${rel}/version.go declares var GitSHA (-X target exists)"
  else
    fail "${rel}/version.go should declare var GitSHA — the ${bin} -X stamp is a silent no-op without it"
  fi
done
if _build_ldflags no-such-binary abc1234 >/dev/null; then
  fail "_build_ldflags should return non-zero for an unknown binary name"
else
  pass "_build_ldflags rejects an unknown binary name"
fi

# 4d. Wiring body-greps: _build_binary must stamp via _build_ldflags, and the
# k8s image build must pass the sha through the GIT_SHA build arg.
bb_body="$(typeset -f _build_binary)"
if print -r -- "$bb_body" | grep -q '_build_ldflags'; then
  pass "_build_binary applies _build_ldflags to go build"
else
  fail "_build_binary should pass _build_ldflags output to go build"
fi
if print -r -- "$bb_body" | grep -q '_dev_git_sha'; then
  pass "_build_binary derives the sha via _dev_git_sha"
else
  fail "_build_binary should call _dev_git_sha"
fi
k8s_body="$(typeset -f cmd_k8s_up)"
if print -r -- "$k8s_body" | grep -q -- '--build-arg GIT_SHA'; then
  pass "cmd_k8s_up passes --build-arg GIT_SHA to docker build"
else
  fail "cmd_k8s_up should pass --build-arg GIT_SHA"
fi

# 5. _decide_mcp_signal: all three branches plus the reflog-unavailable fallback.
# Args: <mcp_rebuilt> <force_all> <reflog_ok> <merge_diff_text>
if [[ "$(_decide_mcp_signal 0 1 1 'backend/cmd/fishhawk-mcp/main.go')" == 0 ]]; then
  pass "_decide_mcp_signal: mcp not rebuilt -> 0"
else
  fail "_decide_mcp_signal: mcp not rebuilt should be 0"
fi
if [[ "$(_decide_mcp_signal 1 1 1 'backend/cmd/fishhawk-mcp/main.go')" == 1 ]]; then
  pass "_decide_mcp_signal: rebuilt + --all + diff touches mcp -> 1"
else
  fail "_decide_mcp_signal: rebuilt + --all + mcp delta should be 1"
fi
if [[ "$(_decide_mcp_signal 1 1 1 'runner/internal/plan/coerce.go')" == 0 ]]; then
  pass "_decide_mcp_signal: rebuilt + --all + diff misses mcp -> 0"
else
  fail "_decide_mcp_signal: rebuilt + --all + non-mcp delta should be 0"
fi
if [[ "$(_decide_mcp_signal 1 1 0 '')" == 1 ]]; then
  pass "_decide_mcp_signal: rebuilt + --all + no reflog -> 1 (fallback)"
else
  fail "_decide_mcp_signal: reflog-unavailable fallback should be 1"
fi
if [[ "$(_decide_mcp_signal 1 0 1 'runner/internal/plan/coerce.go')" == 1 ]]; then
  pass "_decide_mcp_signal: rebuilt under branch-diff up -> 1"
else
  fail "_decide_mcp_signal: branch-diff up rebuild should be 1"
fi

# 5b. Schema-MAJOR bump signal (#1422). The 5th arg forces the banner even when
# mcp was not rebuilt and even when the merge diff misses mcp source — the exact
# false-negative #1422 reported. A 0 (no major change) preserves every prior
# branch result.
if [[ "$(_decide_mcp_signal 0 0 1 'runner/internal/plan/coerce.go' 1)" == 1 ]]; then
  pass "_decide_mcp_signal: schema-major bump forces 1 even when mcp not rebuilt"
else
  fail "_decide_mcp_signal: schema-major bump should force 1 when mcp not rebuilt"
fi
if [[ "$(_decide_mcp_signal 1 1 1 'runner/internal/plan/coerce.go' 1)" == 1 ]]; then
  pass "_decide_mcp_signal: schema-major bump forces 1 even when --all diff misses mcp"
else
  fail "_decide_mcp_signal: schema-major bump should force 1 when diff misses mcp"
fi
if [[ "$(_decide_mcp_signal 0 1 1 'backend/cmd/fishhawk-mcp/main.go' 0)" == 0 ]]; then
  pass "_decide_mcp_signal: major-changed=0 preserves the mcp-not-rebuilt -> 0 branch"
else
  fail "_decide_mcp_signal: major-changed=0 should preserve mcp-not-rebuilt -> 0"
fi
if [[ "$(_decide_mcp_signal 1 1 1 'runner/internal/plan/coerce.go' 0)" == 0 ]]; then
  pass "_decide_mcp_signal: major-changed=0 preserves the --all diff-misses-mcp -> 0 branch"
else
  fail "_decide_mcp_signal: major-changed=0 should preserve --all diff-misses-mcp -> 0"
fi
# Default 5th arg (omitted) is treated as 0 — backward-compatible with old callers.
if [[ "$(_decide_mcp_signal 0 1 1 'backend/cmd/fishhawk-mcp/main.go')" == 0 ]]; then
  pass "_decide_mcp_signal: omitted 5th arg defaults to no-force (0)"
else
  fail "_decide_mcp_signal: omitted 5th arg should default to no-force"
fi

# 5c. _extract_workflow_version_major: pulls the integer major from a version line.
if [[ "$(_extract_workflow_version_major $'version: "0.7"\nworkflows: {}\n')" == 0 ]]; then
  pass "_extract_workflow_version_major: 0.7 -> 0"
else
  fail "_extract_workflow_version_major: 0.7 should yield 0"
fi
if [[ "$(_extract_workflow_version_major $'version: "1.0"\nworkflows: {}\n')" == 1 ]]; then
  pass "_extract_workflow_version_major: 1.0 -> 1"
else
  fail "_extract_workflow_version_major: 1.0 should yield 1"
fi
if [[ -z "$(_extract_workflow_version_major $'workflows: {}\n')" ]]; then
  pass "_extract_workflow_version_major: no version line -> empty"
else
  fail "_extract_workflow_version_major: missing version line should yield empty"
fi

# 5d. _workflow_major_changed: 1 on a major bump, 0 on same major / same minor.
if [[ "$(_workflow_major_changed $'version: "0.7"\n' $'version: "1.0"\n')" == 1 ]]; then
  pass "_workflow_major_changed: 0.7 -> 1.0 (major bump) -> 1"
else
  fail "_workflow_major_changed: 0.7 -> 1.0 should be 1"
fi
if [[ "$(_workflow_major_changed $'version: "0.3"\n' $'version: "0.7"\n')" == 0 ]]; then
  pass "_workflow_major_changed: 0.3 -> 0.7 (same major) -> 0"
else
  fail "_workflow_major_changed: 0.3 -> 0.7 should be 0"
fi
if [[ "$(_workflow_major_changed '' $'version: "1.0"\n')" == 1 ]]; then
  pass "_workflow_major_changed: one side empty (first spec) -> 1"
else
  fail "_workflow_major_changed: one-side-empty should be 1"
fi
if [[ "$(_workflow_major_changed '' '')" == 0 ]]; then
  pass "_workflow_major_changed: both empty -> 0"
else
  fail "_workflow_major_changed: both-empty should be 0"
fi

# 5e. _decide_shim_signal (ADR-060 / #1922): mirrors _decide_mcp_signal's ladder
# minus the schema-major fold. Args: <shim_rebuilt> <force_all> <reflog_ok> <merge_diff>
if [[ "$(_decide_shim_signal 0 1 1 'backend/cmd/fishhawk-mcp-shim/main.go')" == 0 ]]; then
  pass "_decide_shim_signal: shim not rebuilt -> 0"
else
  fail "_decide_shim_signal: shim not rebuilt should be 0"
fi
if [[ "$(_decide_shim_signal 1 1 1 'backend/cmd/fishhawk-mcp-shim/main.go')" == 1 ]]; then
  pass "_decide_shim_signal: rebuilt + --all + diff touches shim -> 1"
else
  fail "_decide_shim_signal: rebuilt + --all + shim delta should be 1"
fi
if [[ "$(_decide_shim_signal 1 1 1 'runner/internal/plan/coerce.go')" == 0 ]]; then
  pass "_decide_shim_signal: rebuilt + --all + diff misses shim -> 0"
else
  fail "_decide_shim_signal: rebuilt + --all + non-shim delta should be 0"
fi
if [[ "$(_decide_shim_signal 1 1 0 '')" == 1 ]]; then
  pass "_decide_shim_signal: rebuilt + --all + no reflog -> 1 (conservative fire)"
else
  fail "_decide_shim_signal: reflog-unavailable fallback should be 1"
fi
if [[ "$(_decide_shim_signal 1 0 1 'runner/internal/plan/coerce.go')" == 1 ]]; then
  pass "_decide_shim_signal: rebuilt under branch-diff up -> 1"
else
  fail "_decide_shim_signal: branch-diff up rebuild should be 1"
fi

# 5f. _shim_registered_from: override wins; empty override consults the text.
if [[ "$(_shim_registered_from 1 '')" == 1 ]]; then
  pass "_shim_registered_from: override 1 -> 1"
else
  fail "_shim_registered_from: override 1 should be 1"
fi
if [[ "$(_shim_registered_from 0 'fishhawk-mcp-shim')" == 0 ]]; then
  pass "_shim_registered_from: override 0 wins over matching text -> 0"
else
  fail "_shim_registered_from: override 0 should be 0"
fi
if [[ "$(_shim_registered_from '' 'command: /path/to/bin/fishhawk-mcp-shim')" == 1 ]]; then
  pass "_shim_registered_from: empty override + matching text -> 1"
else
  fail "_shim_registered_from: empty override + matching text should be 1"
fi
if [[ "$(_shim_registered_from '' 'command: /path/to/bin/fishhawk-mcp')" == 0 ]]; then
  pass "_shim_registered_from: empty override + non-matching text -> 0"
else
  fail "_shim_registered_from: empty override + non-matching text should be 0"
fi
# Empty override + empty text (absent/errored `claude mcp get`) degrades to 0 —
# the fail-safe direction that keeps the manual reconnect banner.
if [[ "$(_shim_registered_from '' '')" == 0 ]]; then
  pass "_shim_registered_from: empty override + empty text degrades to 0 (fail-safe)"
else
  fail "_shim_registered_from: empty override + empty text should degrade to 0"
fi

# 5g. _select_mcp_banner precedence (ADR-060 / #1922). Args:
# <schema_major> <shim_signal> <mcp_signal> <shim_registered>
if [[ "$(_select_mcp_banner 1 0 0 0)" == schema_major ]]; then
  pass "_select_mcp_banner: schema_major kind"
else
  fail "_select_mcp_banner: schema_major input should select schema_major"
fi
if [[ "$(_select_mcp_banner 0 1 0 0)" == shim_rebuilt ]]; then
  pass "_select_mcp_banner: shim_rebuilt kind"
else
  fail "_select_mcp_banner: shim signal should select shim_rebuilt"
fi
if [[ "$(_select_mcp_banner 0 0 1 0)" == reconnect ]]; then
  pass "_select_mcp_banner: reconnect kind (mcp signal, shim unregistered)"
else
  fail "_select_mcp_banner: mcp signal + unregistered shim should select reconnect"
fi
if [[ "$(_select_mcp_banner 0 0 1 1)" == auto_swap ]]; then
  pass "_select_mcp_banner: auto_swap kind (mcp signal, shim registered)"
else
  fail "_select_mcp_banner: mcp signal + registered shim should select auto_swap"
fi
if [[ "$(_select_mcp_banner 0 0 0 0)" == none ]]; then
  pass "_select_mcp_banner: none kind"
else
  fail "_select_mcp_banner: nothing-changed should select none"
fi
# Contested precedences: schema_major beats shim_rebuilt; shim_rebuilt beats auto_swap.
if [[ "$(_select_mcp_banner 1 1 1 1)" == schema_major ]]; then
  pass "_select_mcp_banner: schema_major beats shim_rebuilt"
else
  fail "_select_mcp_banner: schema_major should win over shim_rebuilt"
fi
if [[ "$(_select_mcp_banner 0 1 1 1)" == shim_rebuilt ]]; then
  pass "_select_mcp_banner: shim_rebuilt beats auto_swap"
else
  fail "_select_mcp_banner: shim_rebuilt should win over auto_swap"
fi

# 5h. _detect_rebuild_set wiring (ADR-060 / #1922): the shim carries its own
# trigger glob, and the shared-lib case must NOT short-circuit past the shim.
drs_body="$(typeset -f _detect_rebuild_set)"
if print -r -- "$drs_body" | grep -q 'backend/cmd/fishhawk-mcp-shim/\*'; then
  pass "_detect_rebuild_set carries the fishhawk-mcp-shim trigger glob"
else
  fail "_detect_rebuild_set should carry backend/cmd/fishhawk-mcp-shim/* glob"
fi
# The shared-lib case must fall through (no early `return`) so a diff touching
# both a shared lib AND the shim still marks the shim. Behavioral proof: drive
# _detect_rebuild_set through a stubbed git that emits exactly that two-line diff.
# The subshell isolates the PATH git stub and rebuild_set; its EXIT STATUS carries
# the assertion result back to the parent so pass/fail is counted in the parent
# shell (a pass/fail inside the subshell would increment a copy of the counter
# that is discarded on subshell exit, making the assertion unable to turn the
# suite red).
if (
  set +e
  tmp_stub="$(mktemp -d)"
  cat > "${tmp_stub}/git" <<'STUB'
#!/usr/bin/env zsh
case "$*" in
  *rev-parse*) exit 0 ;;
  *diff*) print "backend/internal/plan/x.go"; print "backend/cmd/fishhawk-mcp-shim/main.go"; exit 0 ;;
  *) exit 0 ;;
esac
STUB
  chmod +x "${tmp_stub}/git"
  PATH="${tmp_stub}:$PATH"
  typeset -gA rebuild_set
  rebuild_set=()
  _detect_rebuild_set
  ok=0
  if [[ -z "${rebuild_set[fishhawk-mcp-shim]:-}" || -z "${rebuild_set[fishhawk-mcp]:-}" ]]; then
    print "  (mcp=${rebuild_set[fishhawk-mcp]:-unset} shim=${rebuild_set[fishhawk-mcp-shim]:-unset})"
    ok=1
  fi
  rm -rf "$tmp_stub"
  exit $ok
); then
  pass "_detect_rebuild_set: shared-lib + shim two-line diff marks BOTH (no early-return drop)"
else
  fail "_detect_rebuild_set: shared-lib + shim diff should mark the shim (see diagnostic above)"
fi

# 5i. Build/banner wiring body-greps: _build_binary src_paths, cmd_up's forced
# --all set, the build loop, and cmd_up's banner-decision call sites all carry
# the shim.
if print -r -- "$bb_body" | grep -q 'fishhawk-mcp-shim'; then
  pass "_build_binary src_paths includes fishhawk-mcp-shim"
else
  fail "_build_binary src_paths should include fishhawk-mcp-shim"
fi
up_body_all="$(typeset -f cmd_up)"
if print -r -- "$up_body_all" | grep -q 'fishhawk-mcp-shim __all__'; then
  pass "cmd_up forced --all set includes fishhawk-mcp-shim"
else
  fail "cmd_up forced --all set should include fishhawk-mcp-shim __all__"
fi
if print -r -- "$up_body_all" | grep -q 'for binary in fishhawkd fishhawk-mcp fishhawk-mcp-shim'; then
  pass "cmd_up build loop iterates fishhawk-mcp-shim"
else
  fail "cmd_up build loop should iterate fishhawk-mcp-shim"
fi
if print -r -- "$up_body_all" | grep -q '_select_mcp_banner'; then
  pass "cmd_up consults _select_mcp_banner for the activation kind"
else
  fail "cmd_up should consult _select_mcp_banner"
fi
if print -r -- "$up_body_all" | grep -q '_detect_shim_registered'; then
  pass "cmd_up consults _detect_shim_registered"
else
  fail "cmd_up should consult _detect_shim_registered"
fi
if print -r -- "$up_body_all" | grep -q '_signal_mcp_activation "$mcp_banner_kind"'; then
  pass "cmd_up emits the selected banner kind as the last line"
else
  fail "cmd_up should call _signal_mcp_activation with the selected kind"
fi

# 7. _healthz_url: derives the port from FISHHAWKD_ADDR, default 8080.
unset FISHHAWKD_ADDR
if [[ "$(_healthz_url)" == "http://localhost:8080/healthz" ]]; then
  pass "_healthz_url defaults to port 8080 when FISHHAWKD_ADDR unset"
else
  fail "_healthz_url should default to 8080 (got: $(_healthz_url))"
fi
FISHHAWKD_ADDR=':9090'
if [[ "$(_healthz_url)" == "http://localhost:9090/healthz" ]]; then
  pass "_healthz_url respects ':9090' override"
else
  fail "_healthz_url should use port 9090 for ':9090' (got: $(_healthz_url))"
fi
FISHHAWKD_ADDR='127.0.0.1:9091'
if [[ "$(_healthz_url)" == "http://localhost:9091/healthz" ]]; then
  pass "_healthz_url respects '127.0.0.1:9091' override"
else
  fail "_healthz_url should use port 9091 for '127.0.0.1:9091' (got: $(_healthz_url))"
fi
unset FISHHAWKD_ADDR

# 7b. _k8s_image_ref / _k8s_healthz_url: pure k8s bring-up helpers, no cluster.
if [[ "$(_k8s_image_ref)" == "ghcr.io/kuhlman-labs/fishhawkd:dev-local" ]]; then
  pass "_k8s_image_ref returns the local dev-local image tag"
else
  fail "_k8s_image_ref should return ghcr.io/kuhlman-labs/fishhawkd:dev-local (got: $(_k8s_image_ref))"
fi
if [[ "$(_k8s_healthz_url)" == "http://localhost:8080/healthz" ]]; then
  pass "_k8s_healthz_url defaults to port 8080"
else
  fail "_k8s_healthz_url should default to 8080 (got: $(_k8s_healthz_url))"
fi
if [[ "$(_k8s_healthz_url 9090)" == "http://localhost:9090/healthz" ]]; then
  pass "_k8s_healthz_url respects an explicit forwarded port"
else
  fail "_k8s_healthz_url should honor port 9090 (got: $(_k8s_healthz_url 9090))"
fi

# 8. _await_healthz: returns non-zero quickly for an already-exited pid (the
# spawn-then-die early-exit path) without needing a live server.
( exit 0 ) &
dead_pid=$!
wait "$dead_pid" 2>/dev/null
if _await_healthz "$dead_pid" "http://localhost:1/healthz" 10; then
  fail "_await_healthz should return non-zero for an already-exited pid"
else
  pass "_await_healthz returns non-zero promptly for a dead pid"
fi

# 9. cmd_up readiness gate: body must poll _await_healthz, tail the log, and
# exit 1 on failure — mirroring the existing cmd_reload body-grep assertions.
up_body="$(typeset -f cmd_up)"
if print -r -- "$up_body" | grep -q '_await_healthz'; then
  pass "cmd_up gates the spawn on _await_healthz"
else
  fail "cmd_up should call _await_healthz after spawning fishhawkd"
fi
if print -r -- "$up_body" | grep -q 'tail -n 15'; then
  pass "cmd_up tails the log on a failed readiness gate"
else
  fail "cmd_up should tail the log on readiness-gate failure"
fi
if print -r -- "$up_body" | grep -q 'exit 1'; then
  pass "cmd_up exits non-zero on a failed readiness gate"
else
  fail "cmd_up should exit 1 on readiness-gate failure"
fi

# 9a. cmd_up serve launch re-enables the child-completion sweeper (#1238): the
# fan-in backstop is off by default in fishhawkd, so the local serve must pass
# --enable-child-completion-sweeper or a settled decomposed parent stays parked
# in awaiting_children with no consolidated branch/PR. Body-grep so a future
# edit that drops the flag fails here.
if print -r -- "$up_body" | grep -q -- '--enable-child-completion-sweeper'; then
  pass "cmd_up serve enables the child-completion sweeper (local fan-in backstop)"
else
  fail "cmd_up serve should pass --enable-child-completion-sweeper so local decompositions fan in"
fi

# 9b. cmd_k8s_up readiness gate: like cmd_up, the body must poll _await_healthz,
# tail the pod logs, and exit 1 on failure so a future edit can't silently drop
# the fail-loud guarantee of the Docker-Desktop bring-up.
k8s_up_body="$(typeset -f cmd_k8s_up)"
if print -r -- "$k8s_up_body" | grep -q '_await_healthz'; then
  pass "cmd_k8s_up gates the bring-up on _await_healthz"
else
  fail "cmd_k8s_up should call _await_healthz after the port-forward"
fi
if print -r -- "$k8s_up_body" | grep -q 'kubectl logs'; then
  pass "cmd_k8s_up tails pod logs on a failed readiness gate"
else
  fail "cmd_k8s_up should tail kubectl logs on readiness-gate failure"
fi
if print -r -- "$k8s_up_body" | grep -q 'exit 1'; then
  pass "cmd_k8s_up exits non-zero on a failed readiness gate"
else
  fail "cmd_k8s_up should exit 1 on readiness-gate failure"
fi
# The rollout leg must catch its own failure (`if ! kubectl rollout status`)
# rather than letting set -e abort before diagnostics run — otherwise a
# CrashLoopBackOff pod exits with no `kubectl logs` tail. Lock that guard so a
# future edit can't silently regress the rollout-failure leg of the contract.
if print -r -- "$k8s_up_body" | grep -q 'if ! kubectl rollout status'; then
  pass "cmd_k8s_up guards the rollout failure and tails diagnostics"
else
  fail "cmd_k8s_up should wrap kubectl rollout status in an 'if !' failure guard"
fi
# The jaeger trace-collector forward (dev-only) must be Service-guarded so a
# jaeger-disabled override is a clean skip, and its pid tracked in its own file
# so k8s-down can kill exactly that forward.
if print -r -- "$k8s_up_body" | grep -q 'kubectl get svc fishhawk-jaeger'; then
  pass "cmd_k8s_up guards the jaeger forward on the Service existing"
else
  fail "cmd_k8s_up should guard the jaeger port-forward on 'kubectl get svc fishhawk-jaeger'"
fi
if print -r -- "$k8s_up_body" | grep -q 'K8S_JAEGER_PF_PID_FILE'; then
  pass "cmd_k8s_up tracks the jaeger forward pid in K8S_JAEGER_PF_PID_FILE"
else
  fail "cmd_k8s_up should record the jaeger forward pid in K8S_JAEGER_PF_PID_FILE"
fi

# 9c. cmd_k8s_down teardown: a genuine helm error must not be swallowed and
# misreported as 'nothing to uninstall'. Only an absent release ('not found')
# is a no-op; any other failure exits non-zero.
k8s_down_body="$(typeset -f cmd_k8s_down)"
if print -r -- "$k8s_down_body" | grep -q 'not found'; then
  pass "cmd_k8s_down treats an absent release ('not found') as a no-op"
else
  fail "cmd_k8s_down should special-case the 'not found' release"
fi
if print -r -- "$k8s_down_body" | grep -q 'exit 1'; then
  pass "cmd_k8s_down exits non-zero on a genuine helm uninstall failure"
else
  fail "cmd_k8s_down should exit 1 on a non-'not found' helm error"
fi
# The jaeger forward (when present) must be torn down alongside the fishhawkd one.
if print -r -- "$k8s_down_body" | grep -q 'K8S_JAEGER_PF_PID_FILE'; then
  pass "cmd_k8s_down kills the tracked jaeger port-forward"
else
  fail "cmd_k8s_down should kill the jaeger forward via K8S_JAEGER_PF_PID_FILE"
fi

# 10. ZERR diagnostic trap (#631): installed, reports the ERROR-SITE file:line
# (not the trap's own body line), propagates the exit code, and the hardening
# can't silently regress.
if (( ${+functions[TRAPZERR]} )); then
  pass "TRAPZERR diagnostic trap is installed"
else
  fail "TRAPZERR should be defined/installed as the ZERR trap"
fi
# Sourcing scripts/dev installed TRAPZERR into THIS test process; neutralize it
# here so its stderr doesn't pollute the test's own output (the assertions below
# intentionally drive a fixture subprocess that exits non-zero, and the harness
# itself exits non-zero on failure). The fixture re-sources scripts/dev, so it
# exercises the real trap in isolation.
unfunction TRAPZERR 2>/dev/null
trap - ZERR

# Error-site precision: a fixture that fails on a KNOWN line (line 5) must be
# named by the diagnostic. Sources the real scripts/dev so the actual TRAPZERR
# fires; funcfiletrace[1] must point at the fixture's failing line, not the trap
# body's line inside scripts/dev.
zerr_fixture="$(mktemp -t test-dev-zerr.XXXXXX)"
cat > "$zerr_fixture" <<EOF
#!/usr/bin/env zsh
set -euo pipefail
DEV_LIB_ONLY=1 source "${REPO_ROOT}/scripts/dev"
true
( exit 7 )
EOF
zerr_out="$(zsh "$zerr_fixture" 2>&1 1>/dev/null)"
zerr_rc=$?
rm -f "$zerr_fixture"
if (( zerr_rc == 7 )); then
  pass "ZERR abort propagates the failing exit code (7), never zero-output exit 0"
else
  fail "fixture should exit 7 under set -e (got rc=$zerr_rc)"
fi
if [[ "$zerr_out" == *"exit 7"* ]]; then
  pass "TRAPZERR reports the failing command's exit code (exit 7)"
else
  fail "TRAPZERR should report 'exit 7' (got: $zerr_out)"
fi
if [[ "$zerr_out" == *line* ]]; then
  pass "TRAPZERR diagnostic includes 'line'"
else
  fail "TRAPZERR diagnostic should include 'line' (got: $zerr_out)"
fi
if [[ "$zerr_out" == *:5* ]]; then
  pass "TRAPZERR names the error-site line (fixture line 5)"
else
  fail "TRAPZERR should name the failing line :5 (got: $zerr_out)"
fi
if [[ "$zerr_out" == */scripts/dev:* ]]; then
  fail "TRAPZERR named scripts/dev — should report the error site, not its own trap line (got: $zerr_out)"
else
  pass "TRAPZERR reports the error site, not the trap's internal scripts/dev line"
fi

# Hardening guard: no fragile `]] && <var>=` assignment-RHS pattern may remain in
# scripts/dev — that bare-&&-in-a-non-tested-context form is the ERR_EXIT hazard
# this change removed, and it must not silently creep back.
if grep -nE '\]\] &&[[:space:]]+[A-Za-z_][A-Za-z0-9_]*(\[[^]]*\])?=' "${REPO_ROOT}/scripts/dev"; then
  fail "scripts/dev still has a fragile ']] && var=' assignment (ERR_EXIT hazard)"
else
  pass "no fragile ']] && var=' assignment remains in scripts/dev"
fi

# The confirmed #631 trigger: `(( i++ ))` returns exit 1 when i==0 (post-increment
# yields the old value, and (( 0 )) is false), aborting the loop body under set -e.
# Guard that no post-increment arithmetic counter survives in scripts/dev.
if grep -nE '\(\([[:space:]]*[A-Za-z_][A-Za-z0-9_]*\+\+[[:space:]]*\)\)' "${REPO_ROOT}/scripts/dev"; then
  fail "scripts/dev still has a '(( var++ ))' post-increment (set -e abort at var==0, #631)"
else
  pass "no fragile '(( var++ ))' post-increment remains in scripts/dev"
fi

# The replacement `(( ++i ))` counter loop is ERR_EXIT-safe from i==0: the body
# must run and the loop complete without aborting under set -e.
if ( set -e; i=0; while (( i < 2 )); do (( ++i )); done; print "$i" ) >/dev/null 2>&1; then
  pass "'(( ++i ))' counter loop from i==0 does not abort under set -e"
else
  fail "'(( ++i ))' counter loop aborted under set -e (the #631 regression)"
fi

# The rewritten `if [[ false-cond ]]; then var=1; fi` form is ERR_EXIT-safe: a
# false condition must NOT abort under set -e (the `[[ ]]` is the if-condition, a
# tested context). zsh's ERR_EXIT-vs-`&&` interaction is subtle and version-
# dependent — the explicit if-form removes that ambiguity entirely, which is the
# point of the hardening.
if ( set -e; v=0; if [[ 1 == 2 ]]; then v=1; fi; print "$v" ) >/dev/null 2>&1; then
  pass "rewritten 'if [[ false ]]; then var=1; fi' does not abort under set -e"
else
  fail "rewritten if-form aborted under set -e (a false condition should be safe)"
fi

# 11. _healthz_port: the shared port derivation up's gate/preflight and down's
# port fallback consume — default 8080 plus the same FISHHAWKD_ADDR override
# matrix _healthz_url has.
unset FISHHAWKD_ADDR
if [[ "$(_healthz_port)" == "8080" ]]; then
  pass "_healthz_port defaults to 8080 when FISHHAWKD_ADDR unset"
else
  fail "_healthz_port should default to 8080 (got: $(_healthz_port))"
fi
FISHHAWKD_ADDR=':9090'
if [[ "$(_healthz_port)" == "9090" ]]; then
  pass "_healthz_port respects ':9090' override"
else
  fail "_healthz_port should yield 9090 for ':9090' (got: $(_healthz_port))"
fi
FISHHAWKD_ADDR='127.0.0.1:9091'
if [[ "$(_healthz_port)" == "9091" ]]; then
  pass "_healthz_port respects '127.0.0.1:9091' override"
else
  fail "_healthz_port should yield 9091 for '127.0.0.1:9091' (got: $(_healthz_port))"
fi
unset FISHHAWKD_ADDR

# 12. _clean_stray_pid_files: tempdir fixture — only the numbered 'dev N.pid'
# strays (#965 shapes) are removed, never dev.pid itself.
stray_dir="$(mktemp -d -t test-dev-strays.XXXXXX)"
touch "$stray_dir/dev.pid" "$stray_dir/dev 2.pid" "$stray_dir/dev 3.pid"
sweep_out="$(_clean_stray_pid_files "$stray_dir")"
if [[ -f "$stray_dir/dev.pid" ]]; then
  pass "_clean_stray_pid_files preserves dev.pid"
else
  fail "_clean_stray_pid_files must never remove dev.pid"
fi
if [[ ! -f "$stray_dir/dev 2.pid" && ! -f "$stray_dir/dev 3.pid" ]]; then
  pass "_clean_stray_pid_files removes the numbered strays"
else
  fail "_clean_stray_pid_files should remove 'dev 2.pid' and 'dev 3.pid'"
fi
if [[ "$sweep_out" == *"dev 2.pid"* && "$sweep_out" == *"dev 3.pid"* ]]; then
  pass "_clean_stray_pid_files prints a notice per removal"
else
  fail "_clean_stray_pid_files should print a notice naming each removed stray (got: $sweep_out)"
fi

# 12b. _clean_stray_nonce_files: tempdir fixture — only the numbered
# 'dev N.nonce' strays (#1623, macOS/iCloud duplicate-name shapes) are
# removed, never the canonical dev.nonce, whose removal cmd_down defers until
# after _down_port_fallback proves listener ownership (#1018).
touch "$stray_dir/dev.nonce" "$stray_dir/dev 2.nonce" "$stray_dir/dev 3.nonce"
nonce_sweep_out="$(_clean_stray_nonce_files "$stray_dir")"
if [[ -f "$stray_dir/dev.nonce" ]]; then
  pass "_clean_stray_nonce_files preserves dev.nonce"
else
  fail "_clean_stray_nonce_files must never remove dev.nonce"
fi
if [[ ! -f "$stray_dir/dev 2.nonce" && ! -f "$stray_dir/dev 3.nonce" ]]; then
  pass "_clean_stray_nonce_files removes the numbered strays"
else
  fail "_clean_stray_nonce_files should remove 'dev 2.nonce' and 'dev 3.nonce'"
fi
if [[ "$nonce_sweep_out" == *"dev 2.nonce"* && "$nonce_sweep_out" == *"dev 3.nonce"* ]]; then
  pass "_clean_stray_nonce_files prints a notice per removal"
else
  fail "_clean_stray_nonce_files should print a notice naming each removed stray (got: $nonce_sweep_out)"
fi

# 13. Listener-identity contract (#965), driven behaviorally with a REAL
# squatter: an `nc -l` background listener on a random high port. lsof only
# inspects (never connects), so nc stays listening for the section's duration.
squat_port=""
for _try in 1 2 3 4 5; do
  cand=$(( 20000 + (RANDOM % 20000) ))
  if [[ -z "$(_port_listeners "$cand")" ]]; then squat_port="$cand"; break; fi
done
free_port=""
for _try in 1 2 3 4 5; do
  cand=$(( 40001 + (RANDOM % 20000) ))
  if [[ "$cand" != "$squat_port" && -z "$(_port_listeners "$cand")" ]]; then free_port="$cand"; break; fi
done
if [[ -z "$squat_port" || -z "$free_port" ]]; then
  fail "could not find two free high ports for the squatter fixture"
else
  nc -l 127.0.0.1 "$squat_port" >/dev/null 2>&1 &
  nc_pid=$!
  # Wait for the bind (up to ~2s); the assertions below fail if nc never binds.
  i=0
  while (( i < 20 )); do
    if [[ -n "$(_port_listeners "$squat_port")" ]]; then break; fi
    sleep 0.1
    (( ++i ))
  done

  if [[ "$(_port_listeners "$squat_port")" == *"$nc_pid"* ]]; then
    pass "_port_listeners finds the nc squatter pid on its port"
  else
    fail "_port_listeners should print the nc pid ${nc_pid} for port ${squat_port} (got: $(_port_listeners "$squat_port"))"
  fi
  if [[ -z "$(_port_listeners "$free_port")" ]]; then
    pass "_port_listeners prints nothing for a free port"
  else
    fail "_port_listeners should be empty for free port ${free_port} (got: $(_port_listeners "$free_port"))"
  fi

  # Expected-pid mismatch: the function must return non-zero, name the actual
  # squatter pid AND the expected pid, and tail the log (the bind-error line).
  squat_log="$(mktemp -t test-dev-squatlog.XXXXXX)"
  print "bind: address already in use (fixture marker)" > "$squat_log"
  vout="$(_verify_listener_identity "$$" "$squat_port" "$squat_log" 2>&1)"
  vrc=$?
  if (( vrc != 0 )); then
    pass "_verify_listener_identity returns non-zero on an expected-pid mismatch"
  else
    fail "_verify_listener_identity should return non-zero when the listener is not the expected pid"
  fi
  if [[ "$vout" == *"$nc_pid"* ]]; then
    pass "_verify_listener_identity diagnostic names the actual squatter pid"
  else
    fail "_verify_listener_identity should name squatter pid ${nc_pid} (got: $vout)"
  fi
  if [[ "$vout" == *"expected pid $$"* ]]; then
    pass "_verify_listener_identity diagnostic names the expected pid"
  else
    fail "_verify_listener_identity should name expected pid $$ (got: $vout)"
  fi
  if [[ "$vout" == *"address already in use"* ]]; then
    pass "_verify_listener_identity tails the log on mismatch"
  else
    fail "_verify_listener_identity should emit the log tail (got: $vout)"
  fi

  # Matching pid: the squatter itself as the expected pid must pass.
  if _verify_listener_identity "$nc_pid" "$squat_port" "$squat_log" >/dev/null 2>&1; then
    pass "_verify_listener_identity returns 0 when the listener IS the expected pid"
  else
    fail "_verify_listener_identity should return 0 for the matching pid ${nc_pid}"
  fi

  # cmd_down port-fallback refuse-success leg: a non-fishhawkd listener (nc) is
  # reported, never killed, and the function returns non-zero.
  dout="$(_down_port_fallback "$squat_port" "$stray_dir/unused.pid" 2>&1)"
  drc=$?
  if (( drc != 0 )); then
    pass "_down_port_fallback refuses success for a non-fishhawkd squatter"
  else
    fail "_down_port_fallback should return non-zero when a foreign process holds the port"
  fi
  if [[ "$dout" == *"$nc_pid"* ]]; then
    pass "_down_port_fallback names the foreign squatter pid"
  else
    fail "_down_port_fallback should name pid ${nc_pid} (got: $dout)"
  fi
  if kill -0 "$nc_pid" 2>/dev/null; then
    pass "_down_port_fallback did not kill the non-fishhawkd listener"
  else
    fail "_down_port_fallback must never kill a non-fishhawkd process"
  fi
  if _down_port_fallback "$free_port" "$stray_dir/unused.pid" >/dev/null 2>&1; then
    pass "_down_port_fallback returns 0 for a free port"
  else
    fail "_down_port_fallback should return 0 when the port is free"
  fi

  kill "$nc_pid" 2>/dev/null
  wait "$nc_pid" 2>/dev/null
  rm -f "$squat_log"
fi
rm -rf "$stray_dir"

# 13b. Call-site wiring (#965) — body-greps only; the control flow itself is
# behaviorally covered above. cmd_up must run the pre-spawn preflight
# (_port_listeners) and the post-gate identity check; cmd_down must compose
# _down_port_fallback and keep the refuse-success exit; both sweep strays.
if print -r -- "$up_body" | grep -q '_port_listeners'; then
  pass "cmd_up runs the pre-spawn port preflight (_port_listeners)"
else
  fail "cmd_up should preflight the port via _port_listeners before spawning"
fi
if print -r -- "$up_body" | grep -q '_verify_listener_identity'; then
  pass "cmd_up runs the post-gate listener-identity check"
else
  fail "cmd_up should call _verify_listener_identity after _await_healthz"
fi
if print -r -- "$up_body" | grep -q '_clean_stray_pid_files'; then
  pass "cmd_up sweeps stray pid files"
else
  fail "cmd_up should call _clean_stray_pid_files"
fi
if print -r -- "$up_body" | grep -q '_clean_stray_nonce_files'; then
  pass "cmd_up sweeps stray nonce files"
else
  fail "cmd_up should call _clean_stray_nonce_files"
fi
down_body="$(typeset -f cmd_down)"
if print -r -- "$down_body" | grep -q '_down_port_fallback'; then
  pass "cmd_down composes the port fallback (_down_port_fallback)"
else
  fail "cmd_down should call _down_port_fallback"
fi
if print -r -- "$down_body" | grep -q 'exit 1'; then
  pass "cmd_down exits non-zero when the port fallback refuses success"
else
  fail "cmd_down should exit 1 on a refused port fallback"
fi
if print -r -- "$down_body" | grep -q '_clean_stray_pid_files'; then
  pass "cmd_down sweeps stray pid files"
else
  fail "cmd_down should call _clean_stray_pid_files"
fi
if print -r -- "$down_body" | grep -q '_clean_stray_nonce_files'; then
  pass "cmd_down sweeps stray nonce files"
else
  fail "cmd_down should call _clean_stray_nonce_files"
fi
# lsof-missing degraded mode: the identity layer must guard on `command -v
# lsof` (warn-and-degrade, never a broken up/down on a host without it).
if grep -q 'command -v lsof' "${REPO_ROOT}/scripts/dev"; then
  pass "scripts/dev guards the lsof-based checks on 'command -v lsof'"
else
  fail "scripts/dev should guard lsof usage with 'command -v lsof'"
fi

# 14. Start-nonce listener identity (#1018) — pure helpers.
nonce1="$(_generate_start_nonce)"
nonce2="$(_generate_start_nonce)"
if [[ -n "$nonce1" ]]; then
  pass "_generate_start_nonce emits a non-empty nonce"
else
  fail "_generate_start_nonce should emit a non-empty nonce"
fi
if print -r -- "$nonce1" | grep -qE '^[0-9a-f]+$'; then
  pass "_generate_start_nonce emits hex-only output"
else
  fail "_generate_start_nonce should be hex-only (got: $nonce1)"
fi
if [[ "$nonce1" != "$nonce2" ]]; then
  pass "_generate_start_nonce differs across calls"
else
  fail "_generate_start_nonce should differ across calls (got twice: $nonce1)"
fi

# _nonce_from_healthz_body: the compact Go-marshaled body shape (no whitespace
# around the colon — the exact bytes TestHandleHealth_StartNonce pins on the
# backend side of the seam), the field-absent case, and a full healthz body.
if [[ "$(_nonce_from_healthz_body '{"status":"ok","start_nonce":"cafe1234"}')" == "cafe1234" ]]; then
  pass "_nonce_from_healthz_body extracts the nonce from a compact body"
else
  fail "_nonce_from_healthz_body should extract cafe1234 (got: $(_nonce_from_healthz_body '{"status":"ok","start_nonce":"cafe1234"}'))"
fi
full_body='{"status":"ok","version":"dev","git_sha":"unknown","min_runner_version":"dev","schemas":{"plan-standard-v1":"abc","workflow-v0":"def"},"start_nonce":"feedbeef"}'
if [[ "$(_nonce_from_healthz_body "$full_body")" == "feedbeef" ]]; then
  pass "_nonce_from_healthz_body extracts the nonce from a full healthz body"
else
  fail "_nonce_from_healthz_body should extract feedbeef (got: $(_nonce_from_healthz_body "$full_body"))"
fi
if [[ -z "$(_nonce_from_healthz_body '{"status":"ok","version":"dev"}')" ]]; then
  pass "_nonce_from_healthz_body prints nothing when the field is absent"
else
  fail "_nonce_from_healthz_body should print nothing for a nonce-less body (got: $(_nonce_from_healthz_body '{"status":"ok","version":"dev"}'))"
fi

# 14b. _verify_healthz_nonce against a REAL curl + one-shot fake responder.
# macOS/BSD nc without -k serves exactly one connection then exits, so each
# assertion gets its own responder instance (same fixture family as section 13).
_find_free_port() {
  local cand
  for _try in 1 2 3 4 5; do
    cand=$(( 20000 + (RANDOM % 40000) ))
    if [[ -z "$(_port_listeners "$cand")" ]]; then print "$cand"; return 0; fi
  done
  return 1
}
# Serve one canned HTTP 200 with <body> on <port>; sets responder_pid. Waits
# for the bind (up to ~2s) so the caller's curl can't race the listener.
_serve_healthz_once() {
  local port="$1"
  local body="$2"
  printf 'HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: %d\r\nConnection: close\r\n\r\n%s' "${#body}" "$body" | nc -l 127.0.0.1 "$port" >/dev/null 2>&1 &
  responder_pid=$!
  local i=0
  while (( i < 20 )); do
    if [[ -n "$(_port_listeners "$port")" ]]; then break; fi
    sleep 0.1
    (( ++i ))
  done
}

nonce_log="$(mktemp -t test-dev-noncelog.XXXXXX)"
print "bind: address already in use (nonce fixture marker)" > "$nonce_log"

# Mismatch: responder echoes 'aaaa', we expect 'bbbb' → rc=1 and a #628-shaped
# diagnostic naming BOTH nonces plus the log tail.
np="$(_find_free_port)"
if [[ -z "$np" ]]; then
  fail "could not find a free port for the nonce-mismatch responder"
else
  _serve_healthz_once "$np" '{"status":"ok","start_nonce":"aaaa"}'
  nvout="$(_verify_healthz_nonce "http://localhost:${np}/healthz" "bbbb" "$nonce_log" 2>&1)"
  nvrc=$?
  if (( nvrc == 1 )); then
    pass "_verify_healthz_nonce returns 1 on a nonce mismatch"
  else
    fail "_verify_healthz_nonce should return 1 on mismatch (got rc=$nvrc)"
  fi
  if [[ "$nvout" == *aaaa* && "$nvout" == *bbbb* ]]; then
    pass "_verify_healthz_nonce diagnostic names both the actual and expected nonce"
  else
    fail "_verify_healthz_nonce diagnostic should name aaaa and bbbb (got: $nvout)"
  fi
  if [[ "$nvout" == *"address already in use"* ]]; then
    pass "_verify_healthz_nonce tails the log on mismatch"
  else
    fail "_verify_healthz_nonce should emit the log tail (got: $nvout)"
  fi
  wait "$responder_pid" 2>/dev/null
fi

# Degraded path: a body WITHOUT start_nonce (pre-#1018 binary) → rc=2, so
# cmd_up falls back to the #965 pid identity check instead of failing.
np="$(_find_free_port)"
if [[ -z "$np" ]]; then
  fail "could not find a free port for the nonce-less responder"
else
  _serve_healthz_once "$np" '{"status":"ok","version":"dev"}'
  _verify_healthz_nonce "http://localhost:${np}/healthz" "bbbb" "$nonce_log" >/dev/null 2>&1
  nvrc=$?
  if (( nvrc == 2 )); then
    pass "_verify_healthz_nonce returns 2 when the body carries no start_nonce"
  else
    fail "_verify_healthz_nonce should return 2 for a nonce-less body (got rc=$nvrc)"
  fi
  wait "$responder_pid" 2>/dev/null
fi

# 14c. _down_port_fallback nonce ladder (#1018 / approval amendment): the nonce
# only UPGRADES confidence, never blocks the #965 path.
nonce_dir="$(mktemp -d -t test-dev-nonce.XXXXXX)"
print "bbbb" > "$nonce_dir/dev.nonce"

# No start_nonce in the body while our nonce file exists → must DEGRADE to the
# comm-basename heuristic (which reports/refuses the foreign listener), not a
# nonce-specific refuse leg.
np="$(_find_free_port)"
if [[ -z "$np" ]]; then
  fail "could not find a free port for the degraded down-fallback responder"
else
  _serve_healthz_once "$np" '{"status":"ok","version":"dev"}'
  dnout="$(_down_port_fallback "$np" "$nonce_dir/unused.pid" "$nonce_dir/dev.nonce" 2>&1)"
  dnrc=$?
  if (( dnrc != 0 )); then
    pass "_down_port_fallback (no start_nonce in body) refuses success via the comm route"
  else
    fail "_down_port_fallback should return non-zero for a nonce-less foreign listener (got rc=$dnrc)"
  fi
  if [[ "$dnout" == *"not fishhawkd"* ]]; then
    pass "_down_port_fallback (no start_nonce in body) takes the comm-heuristic route"
  else
    fail "_down_port_fallback should report via the comm heuristic ('not fishhawkd') (got: $dnout)"
  fi
  wait "$responder_pid" 2>/dev/null
fi

# Exact nonce match → proven ours: the kill leg is taken with nonce-verified
# provenance (the one-shot responder has already exited by then, so the TERM
# is a no-op — the assertion is on the route, not the kill outcome).
np="$(_find_free_port)"
if [[ -z "$np" ]]; then
  fail "could not find a free port for the nonce-match down-fallback responder"
else
  _serve_healthz_once "$np" '{"status":"ok","start_nonce":"bbbb"}'
  dnout="$(_down_port_fallback "$np" "$nonce_dir/unused.pid" "$nonce_dir/dev.nonce" 2>&1)"
  dnrc=$?
  if (( dnrc == 0 )); then
    pass "_down_port_fallback (nonce match) reports a clean takedown"
  else
    fail "_down_port_fallback should return 0 on a nonce-verified takedown (got rc=$dnrc, out: $dnout)"
  fi
  if [[ "$dnout" == *"nonce-verified"* ]]; then
    pass "_down_port_fallback (nonce match) takes the nonce-verified kill leg"
  else
    fail "_down_port_fallback should report 'nonce-verified' on an exact match (got: $dnout)"
  fi
  wait "$responder_pid" 2>/dev/null
fi
rm -f "$nonce_log"
rm -rf "$nonce_dir"

# 14d. Call-site wiring (#1018) — body-greps in the section-13b style.
if print -r -- "$up_body" | grep -q '_generate_start_nonce'; then
  pass "cmd_up generates a per-spawn start nonce"
else
  fail "cmd_up should call _generate_start_nonce before the spawn"
fi
if print -r -- "$up_body" | grep -q '_verify_healthz_nonce'; then
  pass "cmd_up verifies the start_nonce round-trip"
else
  fail "cmd_up should call _verify_healthz_nonce after the readiness gate"
fi
await_line="$(print -r -- "$up_body" | grep -n '_await_healthz' | head -n 1 | cut -d: -f1)"
nonce_line="$(print -r -- "$up_body" | grep -n '_verify_healthz_nonce' | head -n 1 | cut -d: -f1)"
if [[ -n "$await_line" && -n "$nonce_line" ]] && (( await_line < nonce_line )); then
  pass "cmd_up runs _verify_healthz_nonce AFTER the _await_healthz gate"
else
  fail "cmd_up should order _await_healthz before _verify_healthz_nonce (await=$await_line nonce=$nonce_line)"
fi
if print -r -- "$up_body" | grep -q '_verify_listener_identity'; then
  pass "cmd_up retains the #965 pid-check fallback (_verify_listener_identity)"
else
  fail "cmd_up should keep _verify_listener_identity as the rc=2 degraded fallback"
fi
dpf_body="$(typeset -f _down_port_fallback)"
if print -r -- "$dpf_body" | grep -q '_nonce_from_healthz_body'; then
  pass "_down_port_fallback consults the nonce before comm matching"
else
  fail "_down_port_fallback should call _nonce_from_healthz_body"
fi
if print -r -- "$down_body" | grep -qE 'rm -f .*NONCE_FILE'; then
  pass "cmd_down removes the nonce file on teardown"
else
  fail "cmd_down should rm the NONCE_FILE"
fi

# 15. Acceptance preview (E31.18 / #1569) — pure DB derivation. The preview
# database name must be the base name with an `_preview` suffix and can NEVER
# equal the base name, so a preview start can never DROP the dev database.
base_db_url='postgres://fishhawk:fishhawk@localhost:5432/fishhawk?sslmode=disable'
out="$(_preview_db_name "$base_db_url")"
if [[ "$out" == "fishhawk_preview" ]]; then
  pass "_preview_db_name suffixes the database name with _preview"
else
  fail "_preview_db_name should yield fishhawk_preview (got: $out)"
fi
if [[ "$out" != "fishhawk" ]]; then
  pass "_preview_db_name never equals the base database name"
else
  fail "_preview_db_name must never equal the base name"
fi
out="$(_preview_db_name 'postgres://u:p@h:5432/mydb')"
if [[ "$out" == "mydb_preview" ]]; then
  pass "_preview_db_name handles a query-less URL"
else
  fail "_preview_db_name should yield mydb_preview for a query-less URL (got: $out)"
fi
if _preview_db_name 'postgres://u:p@h:5432' >/dev/null; then
  fail "_preview_db_name should return non-zero for a URL with no database name"
else
  pass "_preview_db_name rejects a URL with no database name"
fi
# _preview_db_url now swaps BOTH the database name AND the userinfo for the
# least-privilege role (E31.19 / #1577) — the credential handed to the untrusted
# branch binary must NOT be the operator's fishhawk:fishhawk superuser.
out="$(_preview_db_url "$base_db_url")"
if [[ "$out" == 'postgres://fishhawk_preview:fishhawk_preview@localhost:5432/fishhawk_preview?sslmode=disable' ]]; then
  pass "_preview_db_url swaps role+database and preserves the query string"
else
  fail "_preview_db_url should yield the least-privilege URL keeping ?sslmode (got: $out)"
fi
# Done-means behavioral assertion (#1577): the preview URL must NOT bear the
# operator's superuser credential.
if [[ "$out" != *'fishhawk:fishhawk@'* ]]; then
  pass "_preview_db_url does NOT carry the operator's fishhawk:fishhawk credential"
else
  fail "_preview_db_url leaked the operator credential into the branch-exec URL (got: $out)"
fi
out="$(_preview_db_url 'postgres://u:p@h:5432/mydb')"
if [[ "$out" == 'postgres://fishhawk_preview:fishhawk_preview@h:5432/mydb_preview' ]]; then
  pass "_preview_db_url handles a query-less URL"
else
  fail "_preview_db_url should yield .../mydb_preview with role creds (got: $out)"
fi
if _preview_db_url 'postgres://u:p@h:5432' >/dev/null; then
  fail "_preview_db_url should return non-zero for a URL with no database name"
else
  pass "_preview_db_url rejects a URL with no database name"
fi
# Role/password override knobs (default + FISHHAWK_PREVIEW_DB_* overrides).
if [[ "$(_preview_db_role)" == "fishhawk_preview" && "$(_preview_db_password)" == "fishhawk_preview" ]]; then
  pass "_preview_db_role/_preview_db_password default to fishhawk_preview"
else
  fail "_preview_db_role/_preview_db_password should default to fishhawk_preview"
fi
out="$(FISHHAWK_PREVIEW_DB_ROLE='pv_role' FISHHAWK_PREVIEW_DB_PASSWORD='pv_pw' _preview_db_url "$base_db_url")"
if [[ "$out" == 'postgres://pv_role:pv_pw@localhost:5432/fishhawk_preview?sslmode=disable' ]]; then
  pass "_preview_db_url honors the FISHHAWK_PREVIEW_DB_ROLE/PASSWORD overrides"
else
  fail "_preview_db_url should splice the role/password overrides (got: $out)"
fi
# _db_name_from_url: the shared bare-name parser (used for the dev DB too).
if [[ "$(_db_name_from_url "$base_db_url")" == "fishhawk" ]]; then
  pass "_db_name_from_url extracts the bare database name (query dropped)"
else
  fail "_db_name_from_url should yield fishhawk (got: $(_db_name_from_url "$base_db_url"))"
fi
if _db_name_from_url 'postgres://u:p@h:5432' >/dev/null; then
  fail "_db_name_from_url should return non-zero for a URL with no database name"
else
  pass "_db_name_from_url rejects a URL with no database name"
fi

# 15a. Preview address/port derivation: default localhost:8090 (distinct from
# the orchestrating 8080), FISHHAWK_PREVIEW_ADDR override honored.
unset FISHHAWK_PREVIEW_ADDR
if [[ "$(_preview_port)" == "8090" ]]; then
  pass "_preview_port defaults to 8090 when FISHHAWK_PREVIEW_ADDR unset"
else
  fail "_preview_port should default to 8090 (got: $(_preview_port))"
fi
if [[ "$(_preview_healthz_url)" == "http://localhost:8090/healthz" ]]; then
  pass "_preview_healthz_url defaults to port 8090"
else
  fail "_preview_healthz_url should default to 8090 (got: $(_preview_healthz_url))"
fi
FISHHAWK_PREVIEW_ADDR='localhost:9191'
if [[ "$(_preview_port)" == "9191" ]]; then
  pass "_preview_port respects the FISHHAWK_PREVIEW_ADDR override"
else
  fail "_preview_port should yield 9191 for 'localhost:9191' (got: $(_preview_port))"
fi
unset FISHHAWK_PREVIEW_ADDR

# 15b. _git_sha_from_healthz_body: compact Go-marshaled shape (same seam
# discipline as _nonce_from_healthz_body), and the field-absent case.
full_sha_body='{"status":"ok","version":"dev","git_sha":"abc1234","min_runner_version":"dev","start_nonce":"feedbeef"}'
if [[ "$(_git_sha_from_healthz_body "$full_sha_body")" == "abc1234" ]]; then
  pass "_git_sha_from_healthz_body extracts git_sha from a full healthz body"
else
  fail "_git_sha_from_healthz_body should extract abc1234 (got: $(_git_sha_from_healthz_body "$full_sha_body"))"
fi
if [[ -z "$(_git_sha_from_healthz_body '{"status":"ok","version":"dev"}')" ]]; then
  pass "_git_sha_from_healthz_body prints nothing when git_sha is absent"
else
  fail "_git_sha_from_healthz_body should print nothing for a sha-less body"
fi

# 15c. _await_preview_healthz behavior: the git_sha-gated readiness poll.
# Dead pid → prompt non-zero (spawn-then-die fails fast, mirroring section 8).
( exit 0 ) &
dead_pid=$!
wait "$dead_pid" 2>/dev/null
if _await_preview_healthz "$dead_pid" "http://localhost:1/healthz" "abc1234" 10; then
  fail "_await_preview_healthz should return non-zero for an already-exited pid"
else
  pass "_await_preview_healthz returns non-zero promptly for a dead pid"
fi
# Matching git_sha → 0 (one-shot responder; our own live pid stands in for the
# spawned daemon).
np="$(_find_free_port)"
if [[ -z "$np" ]]; then
  fail "could not find a free port for the preview-readiness responder"
else
  _serve_healthz_once "$np" '{"status":"ok","git_sha":"abc1234"}'
  if _await_preview_healthz "$$" "http://localhost:${np}/healthz" "abc1234" 5; then
    pass "_await_preview_healthz returns 0 when /healthz echoes the expected git_sha"
  else
    fail "_await_preview_healthz should verify a matching git_sha"
  fi
  wait "$responder_pid" 2>/dev/null
fi
# Mismatched git_sha → non-zero at deadline: serving is not enough, the
# listener must BE the expected build (identity-gated readiness).
np="$(_find_free_port)"
if [[ -z "$np" ]]; then
  fail "could not find a free port for the preview-mismatch responder"
else
  _serve_healthz_once "$np" '{"status":"ok","git_sha":"aaaa111"}'
  if _await_preview_healthz "$$" "http://localhost:${np}/healthz" "bbb2222" 1; then
    fail "_await_preview_healthz should NOT verify a mismatched git_sha"
  else
    pass "_await_preview_healthz returns non-zero for a wrong-identity listener"
  fi
  wait "$responder_pid" 2>/dev/null
fi

# 15d. _preview_kill_tracked: behavioral TERM leg + idempotent no-op paths
# (tempdir-parameterized like _clean_stray_pid_files); the KILL escalation leg
# is locked by body-grep below (a TERM-immune fixture would cost 5s per run).
pv_dir="$(mktemp -d -t test-dev-preview.XXXXXX)"
sleep 60 &
pv_pid=$!
print "$pv_pid" > "$pv_dir/preview.pid"
pv_out="$(_preview_kill_tracked "$pv_dir/preview.pid")"
if ! kill -0 "$pv_pid" 2>/dev/null; then
  pass "_preview_kill_tracked terminates the tracked pid"
else
  fail "_preview_kill_tracked should have killed pid ${pv_pid}"
  kill -KILL "$pv_pid" 2>/dev/null
fi
wait "$pv_pid" 2>/dev/null
if [[ ! -f "$pv_dir/preview.pid" ]]; then
  pass "_preview_kill_tracked removes the pid file"
else
  fail "_preview_kill_tracked should remove the pid file"
fi
if _preview_kill_tracked "$pv_dir/preview.pid" >/dev/null; then
  pass "_preview_kill_tracked is a clean no-op when no pid file exists"
else
  fail "_preview_kill_tracked should return 0 for a missing pid file"
fi
kt_body="$(typeset -f _preview_kill_tracked)"
if print -r -- "$kt_body" | grep -q 'kill -TERM' && print -r -- "$kt_body" | grep -q 'kill -KILL'; then
  pass "_preview_kill_tracked escalates TERM -> KILL"
else
  fail "_preview_kill_tracked should carry the TERM -> KILL ladder"
fi

# 15e. _preview_remove_worktree: an unregistered leftover directory is removed
# via the rm -rf fallback; a missing directory is a clean no-op.
mkdir -p "$pv_dir/wt"
touch "$pv_dir/wt/marker"
_preview_remove_worktree "$pv_dir/wt" >/dev/null 2>&1
if [[ ! -d "$pv_dir/wt" ]]; then
  pass "_preview_remove_worktree removes an unregistered leftover directory"
else
  fail "_preview_remove_worktree should remove the directory (fallback rm -rf)"
fi
if _preview_remove_worktree "$pv_dir/wt" >/dev/null 2>&1; then
  pass "_preview_remove_worktree is a clean no-op when the directory is absent"
else
  fail "_preview_remove_worktree should return 0 for a missing directory"
fi
rw_body="$(typeset -f _preview_remove_worktree)"
if print -r -- "$rw_body" | grep -q 'worktree remove --force'; then
  pass "_preview_remove_worktree uses git worktree remove --force"
else
  fail "_preview_remove_worktree should call git worktree remove --force"
fi
rm -rf "$pv_dir"

# 15f. cmd_preview wiring body-greps (section-13b style): detached worktree,
# GitSHA-stamped build, DB reset, git_sha-gated readiness, fail-loud contract.
preview_body="$(typeset -f cmd_preview)"
if print -r -- "$preview_body" | grep -q 'worktree add' && print -r -- "$preview_body" | grep -q -- '--detach'; then
  pass "cmd_preview checks out the merge candidate in a detached worktree"
else
  fail "cmd_preview should git worktree add --detach"
fi
if print -r -- "$preview_body" | grep -q '_build_ldflags'; then
  pass "cmd_preview stamps the preview build via _build_ldflags"
else
  fail "cmd_preview should stamp GitSHA via _build_ldflags"
fi
if print -r -- "$preview_body" | grep -q '_preview_db_reset'; then
  pass "cmd_preview resets the isolated preview database"
else
  fail "cmd_preview should call _preview_db_reset"
fi
if print -r -- "$preview_body" | grep -q '_await_preview_healthz'; then
  pass "cmd_preview gates readiness on the git_sha-verified healthz poll"
else
  fail "cmd_preview should call _await_preview_healthz"
fi
if print -r -- "$preview_body" | grep -q 'migrate up'; then
  pass "cmd_preview migrates the preview database with the preview binary"
else
  fail "cmd_preview should run migrate up against the preview database"
fi
if print -r -- "$preview_body" | grep -q 'tail -n 15'; then
  pass "cmd_preview tails the preview log on a failed readiness gate"
else
  fail "cmd_preview should tail the log on readiness-gate failure"
fi
if print -r -- "$preview_body" | grep -q 'exit 1'; then
  pass "cmd_preview exits non-zero on failure"
else
  fail "cmd_preview should exit 1 on failure"
fi
if print -r -- "$preview_body" | grep -q 'FISHHAWK_PREVIEW_SHA'; then
  pass "cmd_preview defaults its arg to \$FISHHAWK_PREVIEW_SHA (runner-hook bare invocation)"
else
  fail "cmd_preview should default to FISHHAWK_PREVIEW_SHA"
fi
# Fail-loud guard legs (body-greps; the parameterized helpers behind them are
# behaviorally covered above, and the DB-reset-failure teardown was validated
# live): empty ref, missing DB URL, unresolvable ref, port squatter, and
# teardown-on-failure (worktree removal on the post-worktree failure paths).
if print -r -- "$preview_body" | grep -q 'no SHA to preview'; then
  pass "cmd_preview dies loud when neither arg nor FISHHAWK_PREVIEW_SHA is set"
else
  fail "cmd_preview should _die on an empty ref"
fi
if print -r -- "$preview_body" | grep -q 'FISHHAWKD_DATABASE_URL is not set'; then
  pass "cmd_preview dies loud when FISHHAWKD_DATABASE_URL is unset"
else
  fail "cmd_preview should _die on a missing FISHHAWKD_DATABASE_URL"
fi
if print -r -- "$preview_body" | grep -q 'could not resolve'; then
  pass "cmd_preview dies loud on an unresolvable ref (after the direct-fetch retry)"
else
  fail "cmd_preview should _die when the ref resolves to no commit"
fi
if print -r -- "$preview_body" | grep -q '_down_port_fallback'; then
  pass "cmd_preview pre-empts a stale orphan via the port reclaim (_down_port_fallback)"
else
  fail "cmd_preview should compose _down_port_fallback for the preview-port preflight"
fi
if print -r -- "$preview_body" | grep -q "run 'scripts/dev preview-down'"; then
  pass "cmd_preview retains the foreign-case _die guidance ('run scripts/dev preview-down')"
else
  fail "cmd_preview should retain the foreign-holder _die message (binding condition 2)"
fi
if print -r -- "$preview_body" | grep -q '_preview_remove_worktree'; then
  pass "cmd_preview removes the preview worktree on its post-worktree failure paths"
else
  fail "cmd_preview should call _preview_remove_worktree on failure"
fi
db_reset_body="$(typeset -f _preview_db_reset)"
if print -r -- "$db_reset_body" | grep -q 'DROP DATABASE IF EXISTS' && print -r -- "$db_reset_body" | grep -q 'CREATE DATABASE'; then
  pass "_preview_db_reset DROP/CREATEs the preview database"
else
  fail "_preview_db_reset should DROP DATABASE IF EXISTS + CREATE DATABASE"
fi
# The preview DB is OWNED by the least-privilege role (#1577) so it can run
# migrate up in its own database (PG15+ public-schema ownership).
if print -r -- "$db_reset_body" | grep -q 'OWNER'; then
  pass "_preview_db_reset CREATEs the preview database OWNED by the preview role"
else
  fail "_preview_db_reset should carry the OWNER clause"
fi
if print -r -- "$db_reset_body" | grep -q 'docker exec fishhawk-postgres'; then
  pass "_preview_db_reset degrades to psql inside the compose container when the host has none"
else
  fail "_preview_db_reset should carry the docker-exec psql fallback"
fi

# 15i. _preview_role_setup body-greps (E31.19 / #1577): least-privilege role
# provisioning + dev-DB CONNECT denial. Pins the binding approval conditions.
role_setup_body="$(typeset -f _preview_role_setup)"
if print -r -- "$role_setup_body" | grep -q 'CREATE ROLE' \
   && print -r -- "$role_setup_body" | grep -q 'IF NOT EXISTS' \
   && print -r -- "$role_setup_body" | grep -q 'pg_roles'; then
  pass "_preview_role_setup guards CREATE ROLE with WHEN NOT EXISTS (idempotent)"
else
  fail "_preview_role_setup should CREATE ROLE only IF NOT EXISTS (pg_roles)"
fi
if print -r -- "$role_setup_body" | grep -q 'LOGIN'; then
  pass "_preview_role_setup creates a LOGIN role"
else
  fail "_preview_role_setup should create a LOGIN role"
fi
# Binding condition 1: normalize-always via an UNCONDITIONAL ALTER ROLE with the
# least-privilege NOSUPERUSER/NOCREATEROLE attributes, and NO granted SUPERUSER.
if print -r -- "$role_setup_body" | grep -q 'ALTER ROLE' \
   && print -r -- "$role_setup_body" | grep -q 'NOSUPERUSER' \
   && print -r -- "$role_setup_body" | grep -q 'NOCREATEROLE'; then
  pass "_preview_role_setup normalizes via ALTER ROLE … NOSUPERUSER NOCREATEROLE (binding condition 1)"
else
  fail "_preview_role_setup should ALTER ROLE … NOSUPERUSER NOCREATEROLE"
fi
if print -r -- "$role_setup_body" | grep -qE '[[:space:]]SUPERUSER'; then
  fail "_preview_role_setup must NOT grant SUPERUSER"
else
  pass "_preview_role_setup grants no SUPERUSER attribute"
fi
# Binding condition 2: REVOKE CONNECT from PUBLIC *and* explicitly from the role.
if print -r -- "$role_setup_body" | grep -q 'REVOKE CONNECT ON DATABASE' \
   && print -r -- "$role_setup_body" | grep -q 'FROM PUBLIC'; then
  pass "_preview_role_setup revokes CONNECT on the dev DB FROM PUBLIC"
else
  fail "_preview_role_setup should REVOKE CONNECT … FROM PUBLIC"
fi
if print -r -- "$role_setup_body" | grep -q 'FROM ${role}'; then
  pass "_preview_role_setup ALSO revokes CONNECT explicitly FROM the role (binding condition 2)"
else
  fail "_preview_role_setup should REVOKE CONNECT … FROM \${role} in addition to PUBLIC"
fi
if print -r -- "$role_setup_body" | grep -q 'docker exec fishhawk-postgres'; then
  pass "_preview_role_setup degrades to psql inside the compose container when the host has none"
else
  fail "_preview_role_setup should carry the docker-exec psql fallback"
fi

# 15j. cmd_preview wiring (#1577): role setup precedes db reset; both privileged
# ops use base_url (operator creds); the branch binary gets preview_url only.
if print -r -- "$preview_body" | grep -q '_preview_role_setup "$base_url"'; then
  pass "cmd_preview provisions the least-privilege role against base_url (operator creds)"
else
  fail "cmd_preview should call _preview_role_setup with base_url"
fi
if print -r -- "$preview_body" | grep -q '_preview_db_reset "$base_url"'; then
  pass "cmd_preview resets the preview DB against base_url (operator creds)"
else
  fail "cmd_preview should call _preview_db_reset with base_url"
fi
if print -r -- "$preview_body" | grep -q 'FISHHAWKD_DATABASE_URL=$preview_url'; then
  pass "cmd_preview hands the branch binary the least-privilege preview_url"
else
  fail "cmd_preview should exec migrate/serve with FISHHAWKD_DATABASE_URL=\$preview_url"
fi
# base_url (operator superuser creds) must NEVER be spliced into a branch-exec
# FISHHAWKD_DATABASE_URL — only the privileged role-setup/db-reset ops see it.
if print -r -- "$preview_body" | grep -q 'FISHHAWKD_DATABASE_URL=$base_url'; then
  fail "cmd_preview must NOT hand base_url to the branch binary"
else
  pass "cmd_preview never hands base_url to the branch binary"
fi
pd_body="$(typeset -f cmd_preview_down)"
if print -r -- "$pd_body" | grep -q '_preview_kill_tracked' && print -r -- "$pd_body" | grep -q '_down_port_fallback' && print -r -- "$pd_body" | grep -q '_preview_remove_worktree'; then
  pass "cmd_preview_down composes kill + port reclaim + worktree-removal"
else
  fail "cmd_preview_down should call _preview_kill_tracked, _down_port_fallback, and _preview_remove_worktree"
fi

# 15g. Preview-port reclaim (#1675) — behavioral, driving BOTH enumerated modes
# of the ownership heuristic through _down_port_fallback with NO nonce arg (the
# comm-basename route preview daemons take, since they are git_sha-gated, not
# nonce-stamped). This is exactly what cmd_preview_down and cmd_preview's
# preflight compose to reclaim an orphaned :8090 whose pid file is already gone.
if ! command -v nc &>/dev/null; then
  print "skip: nc not found — skipping preview-port reclaim behavioral tests"
else
  reclaim_dir="$(mktemp -d -t test-dev-reclaim.XXXXXX)"
  reclaim_bin="$(mktemp -d -t test-dev-reclaimbin.XXXXXX)"
  absent_pid="$reclaim_dir/preview.pid"   # deliberately never created (#1675)

  # -- Mode 1: reclaim KILL leg. A listener whose comm basename is 'fishhawkd'
  # (nc launched via a 'fishhawkd'-named path) holding a port with the pid file
  # ABSENT is the #1675 orphan; the reclaim must TERM→KILL it and free the
  # port. We SYMLINK rather than cp: copying a signed binary invalidates its
  # signature and macOS SIGKILLs the copy on exec (so the plan's literal cp
  # would always skip here), while exec-via-symlink keeps nc alive AND yields
  # comm=…/fishhawkd on both macOS and Linux. Guard still skips cleanly if even
  # the symlinked listener cannot bind as comm=fishhawkd.
  fhd_port=""
  for _try in 1 2 3 4 5; do
    cand=$(( 20000 + (RANDOM % 40000) ))
    if [[ -z "$(_port_listeners "$cand")" ]]; then fhd_port="$cand"; break; fi
  done
  fhd_bin="$reclaim_bin/fishhawkd"
  ln -s "$(command -v nc)" "$fhd_bin" 2>/dev/null || true
  fhd_pid=""
  if [[ -n "$fhd_port" && -x "$fhd_bin" ]]; then
    "$fhd_bin" -l 127.0.0.1 "$fhd_port" >/dev/null 2>&1 &
    fhd_pid=$!
    i=0
    while (( i < 20 )); do
      if [[ -n "$(_port_listeners "$fhd_port")" ]]; then break; fi
      sleep 0.1
      (( ++i ))
    done
  fi
  fhd_comm=""
  if [[ -n "$fhd_pid" ]]; then fhd_comm="$(ps -p "$fhd_pid" -o comm= 2>/dev/null)"; fi
  if [[ -z "$fhd_pid" ]] || ! kill -0 "$fhd_pid" 2>/dev/null \
     || [[ -z "$(_port_listeners "$fhd_port")" ]] || [[ "${fhd_comm:t}" != fishhawkd ]]; then
    print "skip: 'fishhawkd'-named nc copy could not bind as comm=fishhawkd — skipping the reclaim KILL-leg assertion"
    if [[ -n "$fhd_pid" ]]; then kill "$fhd_pid" 2>/dev/null; wait "$fhd_pid" 2>/dev/null; fi
  else
    rout="$(_down_port_fallback "$fhd_port" "$absent_pid" 2>&1)"
    rrc=$?
    if (( rrc == 0 )); then
      pass "reclaim returns 0 for a pid-file-absent fishhawkd orphan (#1675 done-means)"
    else
      fail "reclaim should return 0 after killing a stale fishhawkd orphan (got rc=$rrc, out: $rout)"
    fi
    if kill -0 "$fhd_pid" 2>/dev/null; then
      fail "reclaim should have TERM→KILLed the fishhawkd orphan pid ${fhd_pid}"
      kill -KILL "$fhd_pid" 2>/dev/null
    else
      pass "reclaim TERM→KILLs the pid-file-absent fishhawkd orphan"
    fi
    wait "$fhd_pid" 2>/dev/null
    if [[ -z "$(_port_listeners "$fhd_port")" ]]; then
      pass "reclaim frees the orphaned preview port"
    else
      fail "reclaim should free port ${fhd_port} (still held: $(_port_listeners "$fhd_port"))"
    fi
  fi

  # -- Mode 2: reclaim FOREIGN-safety leg (binding condition 1). A plain nc
  # listener (comm=nc) must be REPORTED and NOT killed, with the reclaim
  # returning non-zero so preview-down/preflight cannot falsely claim success.
  foreign_port=""
  for _try in 1 2 3 4 5; do
    cand=$(( 20000 + (RANDOM % 40000) ))
    if [[ "$cand" != "$fhd_port" && -z "$(_port_listeners "$cand")" ]]; then foreign_port="$cand"; break; fi
  done
  if [[ -z "$foreign_port" ]]; then
    fail "could not find a free port for the foreign-safety reclaim fixture"
  else
    nc -l 127.0.0.1 "$foreign_port" >/dev/null 2>&1 &
    foreign_pid=$!
    i=0
    while (( i < 20 )); do
      if [[ -n "$(_port_listeners "$foreign_port")" ]]; then break; fi
      sleep 0.1
      (( ++i ))
    done
    frout="$(_down_port_fallback "$foreign_port" "$absent_pid" 2>&1)"
    frrc=$?
    if (( frrc != 0 )); then
      pass "reclaim refuses success (rc!=0) for a foreign :8090 holder"
    else
      fail "reclaim should return non-zero for a non-fishhawkd listener (got rc=$frrc)"
    fi
    if [[ "$frout" == *"$foreign_pid"* ]]; then
      pass "reclaim reports the foreign holder's pid"
    else
      fail "reclaim should name the foreign pid ${foreign_pid} (got: $frout)"
    fi
    if kill -0 "$foreign_pid" 2>/dev/null; then
      pass "reclaim never kills the foreign (comm=nc) listener"
    else
      fail "reclaim must NOT kill a non-fishhawkd process (pid ${foreign_pid})"
    fi
    kill "$foreign_pid" 2>/dev/null
    wait "$foreign_pid" 2>/dev/null
  fi
  rm -rf "$reclaim_dir" "$reclaim_bin"
fi

# 15h. _preview_branch_env: the credential-stripped prefix that runs the
# UNTRUSTED merge-candidate binary (#1569 security fixup). It must be an
# `env -i` boundary (default-deny) and never forward a .env-sourced secret,
# while preserving PATH so the branch binary can still boot.
ANTHROPIC_API_KEY="leaked-model-key" FISHHAWK_GITHUB_TOKEN="leaked-gh-token" FISHHAWK_API_TOKEN="leaked-api-token" _preview_branch_env
if [[ "${reply[1]}" == "env" && "${reply[2]}" == "-i" ]]; then
  pass "_preview_branch_env clears the inherited env via env -i"
else
  fail "_preview_branch_env should start with 'env -i' (got: ${reply[1]} ${reply[2]})"
fi
if print -r -- "${reply[@]}" | grep -q 'leaked-'; then
  fail "_preview_branch_env leaked a secret into the branch-exec env: ${reply[*]}"
else
  pass "_preview_branch_env forwards no runner/.env secret to branch code"
fi
if print -r -- "${reply[@]}" | grep -q "PATH=${PATH}"; then
  pass "_preview_branch_env preserves PATH so the branch binary can boot"
else
  fail "_preview_branch_env should preserve PATH"
fi
if print -r -- "$preview_body" | grep -q '_preview_branch_env'; then
  pass "cmd_preview runs the branch binary through the credential-stripped _preview_branch_env"
else
  fail "cmd_preview should exec migrate up / serve via _preview_branch_env"
fi

# 15k. OPTIONAL live containment test (E31.19 / #1577) — gated on a host psql
# AND a reachable dev Postgres (skips cleanly like the 15g nc block otherwise).
# Drives BOTH enumerated failure modes end-to-end against a real Postgres:
#   mode 1 — the least-privilege preview role CAN connect to its throwaway
#            preview database and create an object (the PG15+ ownership path
#            `migrate up` relies on);
#   mode 2 — that same role CANNOT connect to the dev database (REVOKE CONNECT).
# The block provisions against a UNIQUE throwaway role/DB and RESTORES the dev
# DB's PUBLIC CONNECT grant + drops the role/DB on exit, so a test run leaves no
# durable dev-DB side effect.
if ! command -v psql &>/dev/null; then
  print "skip: psql not found — skipping the live preview-containment test"
elif ! psql "$base_db_url" -v ON_ERROR_STOP=1 -tAc 'SELECT 1' >/dev/null 2>&1; then
  print "skip: dev Postgres unreachable at the base URL — skipping the live preview-containment test"
else
  live_role="fishhawk_preview_selftest_$$"
  live_pw="selftest_pw"
  live_dev_db="$(_db_name_from_url "$base_db_url")"
  live_preview_db="${live_role}_db"
  live_base="${base_db_url%%\?*}"
  live_query=""
  if [[ "$base_db_url" == *\?* ]]; then live_query="?${base_db_url#*\?}"; fi
  live_rest="${live_base#*://}"
  live_authority="${live_rest%%/*}"
  live_hostport="${live_authority##*@}"
  live_scheme="${live_base%%://*}://"
  dev_as_role_url="${live_scheme}${live_role}:${live_pw}@${live_hostport}/${live_dev_db}${live_query}"
  preview_as_role_url="${live_scheme}${live_role}:${live_pw}@${live_hostport}/${live_preview_db}${live_query}"

  # Provision (revokes dev CONNECT) + create the throwaway preview DB owned by
  # the role. Reuses the exact functions under test.
  _preview_role_setup "$base_db_url" "$live_dev_db" "$live_role" "$live_pw" >/dev/null 2>&1
  _preview_db_reset "$base_db_url" "$live_preview_db" "$live_role" >/dev/null 2>&1

  # Mode 1: the preview role connects to its own DB and creates an object.
  if psql "$preview_as_role_url" -v ON_ERROR_STOP=1 -q \
       -c 'CREATE TABLE _fishhawk_selftest(id int)' -c 'DROP TABLE _fishhawk_selftest' >/dev/null 2>&1; then
    pass "live: preview role CAN connect to its preview DB and create objects (mode 1)"
  else
    fail "live: preview role should own its preview DB and run DDL (mode 1)"
  fi

  # Mode 2: the same role is REFUSED a connection to the dev database.
  if psql "$dev_as_role_url" -v ON_ERROR_STOP=1 -tAc 'SELECT 1' >/dev/null 2>&1; then
    fail "live: preview role must NOT be able to connect to the dev DB (mode 2)"
  else
    pass "live: preview role is REFUSED connection to the dev DB (mode 2)"
  fi

  # Cleanup: drop the throwaway DB + role, restore the dev DB PUBLIC CONNECT ACL.
  psql "$base_db_url" -q -c "DROP DATABASE IF EXISTS \"${live_preview_db}\" WITH (FORCE)" >/dev/null 2>&1
  psql "$base_db_url" -q -c "GRANT CONNECT ON DATABASE \"${live_dev_db}\" TO PUBLIC" >/dev/null 2>&1
  psql "$base_db_url" -q -c "DROP ROLE IF EXISTS ${live_role}" >/dev/null 2>&1
fi

# 6. Parse check: scripts/dev is valid zsh.
if zsh -n "${REPO_ROOT}/scripts/dev"; then
  pass "scripts/dev parses clean (zsh -n)"
else
  fail "scripts/dev failed zsh -n parse check"
fi

print ""
print "Results: ${PASS} passed, ${FAIL} failed"
[[ "$FAIL" -eq 0 ]]
