#!/usr/bin/env bash
set -eu

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

for schema in "$REPO_ROOT"/docs/spec/*.schema.json; do
  base="$(basename "$schema")"
  case "$base" in
    plan-standard-*.schema.json)
      cp "$schema" "$REPO_ROOT/backend/internal/plan/schemas/$base"
      cp "$schema" "$REPO_ROOT/runner/internal/plan/schemas/$base"
      ;;
    clarification-request-*.schema.json)
      # The standard_v1 SIBLING schema (#1080) is embedded into the
      # backend plan validator only; the runner handles the
      # clarification_request outcome semantically and does not embed it.
      cp "$schema" "$REPO_ROOT/backend/internal/plan/schemas/$base"
      ;;
    workflow-v*.schema.json)
      cp "$schema" "$REPO_ROOT/backend/internal/spec/schemas/$base"
      cp "$schema" "$REPO_ROOT/cli/internal/spec/schemas/$base"
      ;;
    operator-role*.schema.json)
      cp "$schema" "$REPO_ROOT/backend/internal/operatorrole/schemas/$base"
      ;;
    work-management-v*.schema.json)
      cp "$schema" "$REPO_ROOT/backend/internal/workmgmt/schemas/$base"
      ;;
    *)
      echo "sync-schemas: unrecognized schema file '$base' — skipping (add a case to route it)" >&2
      ;;
  esac
done

# The shipped default operator role spec (ADR-040 D1) is a product
# artifact synced like the schemas, not just an example.
cp "$REPO_ROOT/docs/spec/operator-role-default.yaml" \
  "$REPO_ROOT/backend/internal/operatorrole/defaults/operator-role-default.yaml"

# The shipped default work-management conventions (#1005) are likewise a
# product artifact synced alongside the schema, not just an example.
cp "$REPO_ROOT/docs/spec/work-management-default.yaml" \
  "$REPO_ROOT/backend/internal/workmgmt/defaults/work-management-default.yaml"

echo "schemas synced from docs/spec/"
