#!/usr/bin/env zsh
# scripts/dev — start/stop the local Fishhawk dev stack
set -euo pipefail

REPO_ROOT="${0:A:h:h}"
PID_FILE="${REPO_ROOT}/.fishhawk/dev.pid"
NONCE_FILE="${REPO_ROOT}/.fishhawk/dev.nonce"
K8S_PF_PID_FILE="${REPO_ROOT}/.fishhawk/k8s-pf.pid"
K8S_JAEGER_PF_PID_FILE="${REPO_ROOT}/.fishhawk/k8s-jaeger-pf.pid"
LOG_DIR="${REPO_ROOT}/logs"
LOG_FILE="${LOG_DIR}/fishhawkd.log"
BIN="${REPO_ROOT}/bin/fishhawkd"
# Acceptance preview (E31.18 / #1569): a second fishhawkd built from the run's
# merge-candidate SHA in a detached worktree, serving on its own port against
# its own database. The binary lives INSIDE the worktree so preview-down's
# worktree removal cleans it up with everything else. The worktree sits under
# the already-gitignored .fishhawk/cache/ — a live preview must never show as
# untracked in the main repo, or `git status` goes dirty and _dev_git_sha
# starts stamping dev builds -dirty (which the runner's fail-closed staleness
# probe would then correctly reject).
PREVIEW_PID_FILE="${REPO_ROOT}/.fishhawk/preview.pid"
PREVIEW_WORKTREE="${REPO_ROOT}/.fishhawk/cache/preview-worktree"
PREVIEW_LOG_FILE="${LOG_DIR}/fishhawkd-preview.log"

cmd="${1:-}"

_die() { print -u2 "error: $*"; exit 1 }

# ZERR diagnostic trap. zsh auto-installs a function named TRAPZERR as the ZERR
# (error) trap: it fires on any command returning non-zero in a NON-tested
# context — exactly where `set -e` (ERR_EXIT) would abort. Without this, an
# intermittent top-level abort (issue #631) exits 1 with literally zero output
# and is undiagnosable. We print the failing command's exit code and file:line
# to stderr so the next recurrence pins the exact trigger. Use ${funcfiletrace[1]}
# (the call site of this trap function) — bare ${LINENO} inside a TRAPZERR
# function reports the trap's own internal line in zsh, not the error site.
# Stays silent in normal operation: ZERR does not fire for commands whose status
# is tested by if/while/until/&&/||/! (e.g. _build_binary in an `if`,
# _await_healthz in `if !`, _pg_ready in `&&`/`||`).
TRAPZERR() {
  local code=$?
  print -u2 "scripts/dev: command failed (exit ${code}) at line ${funcfiletrace[1]}"
}

_pg_ready() {
  local host="${PGHOST:-localhost}"
  local port="${PGPORT:-5432}"

  # Parse host:port from DATABASE_URL if set
  if [[ -n "${FISHHAWKD_DATABASE_URL:-}" ]]; then
    local stripped="${FISHHAWKD_DATABASE_URL#*://}"   # drop scheme
    stripped="${stripped#*@}"                          # drop user:pass@
    local hostport="${stripped%%/*}"                   # take host:port before /
    host="${hostport%%:*}"
    port="${hostport##*:}"
    if [[ "$host" == "$port" ]]; then port=5432; fi   # no colon — default port
  fi

  if command -v pg_isready &>/dev/null; then
    pg_isready -h "$host" -p "$port" -q
  else
    nc -z "$host" "$port" 2>/dev/null
  fi
}

_minio_ready() {
  local endpoint="${MINIO_ENDPOINT:-http://localhost:9000}"
  curl --silent --fail --max-time 3 "${endpoint}/minio/health/live" &>/dev/null
}

# Derive the fishhawkd listen port from FISHHAWKD_ADDR (default ':8080').
# FISHHAWKD_ADDR may be ':8080' or '127.0.0.1:8080'; take the port after the
# last colon, defaulting to 8080 when unset/portless. Single source of truth
# for up's readiness gate/preflight and down's port fallback, so all of them
# stay correct if the operator overrides the listen address in .env
# (.env.example documents FISHHAWKD_ADDR defaulting to :8080).
_healthz_port() {
  local addr="${FISHHAWKD_ADDR:-:8080}"
  local port="${addr##*:}"
  if [[ -z "$port" || "$port" == "$addr" ]]; then port=8080; fi
  print "$port"
}

# Health endpoint URL for the port _healthz_port derives.
_healthz_url() {
  print "http://localhost:$(_healthz_port)/healthz"
}

# Pid(s) holding a LISTEN socket on TCP <port>, one per line; prints nothing
# (and exits non-zero, lsof's no-match status) when the port is free. -t emits
# pids only, -sTCP:LISTEN filters to listening state, -nP skips name lookups.
# Callers must guard on `command -v lsof` (warn-and-degrade, never abort) and
# invoke this in a tested context so the free-port non-zero exit stays
# set -e / TRAPZERR quiet (#631 discipline).
_port_listeners() {
  local port="$1"
  lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null
}

# Post-gate listener-identity check (#965): a healthy /healthz proves only that
# SOMETHING answers the port — a stale daemon squatting there satisfies the
# gate while the freshly spawned fishhawkd dies on 'bind: address already in
# use'. Require the pid listening on <port> to be the spawned <expected_pid>;
# on mismatch (a squatter raced in, or the child died right after the poll)
# follow the #628 fail-loud contract: diagnostic naming expected vs actual
# pid(s), `tail -n 15` of <log_file> (which carries the bind error), non-zero
# return. With lsof unavailable, warn and return 0 (degraded: no identity
# check, today's behavior).
_verify_listener_identity() {
  local expected_pid="$1"
  local port="$2"
  local log_file="$3"

  if ! command -v lsof &>/dev/null; then
    print "warning: lsof not found — skipping listener-identity check on port ${port}"
    return 0
  fi

  local listeners=""
  if ! listeners="$(_port_listeners "$port")"; then
    listeners=""
  fi

  local -a lpids=()
  local lpid
  for lpid in "${(f)listeners}"; do
    if [[ -n "$lpid" ]]; then lpids+=("$lpid"); fi
  done

  if (( ${lpids[(Ie)$expected_pid]} )); then
    return 0
  fi

  local actual="${(j:, :)lpids}"
  if [[ -z "$actual" ]]; then actual="none"; fi
  print -u2 "error: port ${port} listener is pid(s) ${actual}, not the spawned fishhawkd (expected pid ${expected_pid}) — stale-daemon squatter (#965)"
  print -u2 "last ${log_file} lines:"
  tail -n 15 "$log_file" >&2
  return 1
}

# Per-spawn opaque identity token (#1018): 16 random bytes, hex-encoded. The
# daemon echoes it back in the /healthz body, so a round-trip match proves the
# listener IS the spawn we started — surviving OS pid reuse, which the #965
# pid comparison cannot. Pure (od/tr are POSIX; no scripts/dev state) so
# scripts/test-dev can assert shape + uniqueness directly.
_generate_start_nonce() {
  od -An -N16 -tx1 /dev/urandom | tr -d ' \n'
}

# Extract the start_nonce value from a /healthz JSON body; prints the nonce or
# nothing when the field is absent. Matches the compact `"key":"value"` shape
# Go's encoding/json emits (no whitespace around the colon) — the backend test
# TestHandleHealth_StartNonce pins that exact byte shape from the other side
# of the seam. Always returns 0 (the grep miss is if-tested) so callers can
# command-substitute it in non-tested contexts under set -e.
_nonce_from_healthz_body() {
  local body="$1"
  local match=""
  if match="$(print -r -- "$body" | grep -Eo '"start_nonce":"[^"]*"' | head -n 1)"; then
    print -r -- "$match" | cut -d'"' -f4
  fi
}

# Nonce round-trip identity check (#1018) — the primary post-gate listener
# identity proof. Curls <url> (same flags as _await_healthz) and compares the
# echoed start_nonce against <expected_nonce>. Returns:
#   0  exact match — the listener is provably the daemon we spawned
#   1  mismatch or curl failure — #628 fail-loud contract: diagnostic naming
#      expected vs actual nonce, `tail -n 15` of <log_file>, to stderr
#   2  body carries no start_nonce field (pre-nonce fishhawkd binary) — the
#      caller degrades to the #965 pid identity check
_verify_healthz_nonce() {
  local url="$1"
  local expected="$2"
  local log_file="$3"

  local body=""
  if ! body="$(curl --silent --fail --max-time 2 "$url" 2>/dev/null)"; then
    print -u2 "error: could not fetch ${url} for the start_nonce identity check (expected nonce ${expected}) (#1018)"
    print -u2 "last ${log_file} lines:"
    tail -n 15 "$log_file" >&2
    return 1
  fi

  if [[ "$body" != *'"start_nonce"'* ]]; then
    return 2
  fi

  local actual=""
  actual="$(_nonce_from_healthz_body "$body")"
  if [[ "$actual" == "$expected" ]]; then
    return 0
  fi

  print -u2 "error: /healthz start_nonce is '${actual}', not the spawned fishhawkd's '${expected}' — the listener is not the daemon we started (#1018)"
  print -u2 "last ${log_file} lines:"
  tail -n 15 "$log_file" >&2
  return 1
}

# cmd_down port fallback (#965): after the pid-file kill (or when the pid file
# is missing), the port must actually be free — 'down succeeded but a daemon
# still serves the port' is the exact false-success shape. If <port> is still
# bound: a listener proven ours by the start_nonce round-trip (#1018), or one
# whose command is fishhawkd, is a stale orphan (lost pid file) — kill it
# TERM→5s→KILL, report it, and remove <pid_file>; anything else is reported to
# stderr and the function returns non-zero, refusing to claim success (another
# tool may legitimately hold the port; killing it from a stack-teardown script
# would be destructive). lsof missing degrades to a warning + success (no port
# check, today's behavior).
_down_port_fallback() {
  local port="$1"
  local pid_file="$2"
  local nonce_file="${3:-}"

  if ! command -v lsof &>/dev/null; then
    print "warning: lsof not found — skipping port ${port} squatter check"
    return 0
  fi

  local listeners=""
  if ! listeners="$(_port_listeners "$port")"; then
    return 0
  fi

  # Nonce upgrade (#1018): when this stack's nonce file exists and the
  # listener's /healthz echoes EXACTLY that nonce, the listener is proven to
  # be our stale fishhawkd — take the kill leg with that provenance. ANY other
  # outcome (no nonce file, healthz unreachable / non-HTTP listener, a body
  # without start_nonce — a pre-nonce binary, or a DIFFERENT nonce — an older
  # spawn's orphan) degrades to the comm-basename heuristic below UNCHANGED:
  # the nonce only upgrades confidence, it never blocks the #965 path.
  local nonce_verified=0
  if [[ -n "$nonce_file" && -f "$nonce_file" ]]; then
    local expected="" body="" actual=""
    expected="$(cat "$nonce_file")"
    if body="$(curl --silent --fail --max-time 2 "http://localhost:${port}/healthz" 2>/dev/null)"; then
      actual="$(_nonce_from_healthz_body "$body")"
      if [[ -n "$expected" && "$actual" == "$expected" ]]; then
        nonce_verified=1
      fi
    fi
  fi

  local lpid comm rc=0
  while IFS= read -r lpid; do
    if [[ -z "$lpid" ]]; then continue; fi
    comm="?"
    if ! comm="$(ps -p "$lpid" -o comm= 2>/dev/null)"; then comm="?"; fi
    if (( nonce_verified )) || [[ "${comm:t}" == "fishhawkd" ]]; then
      kill -TERM "$lpid" 2>/dev/null || true
      local i=0
      while kill -0 "$lpid" 2>/dev/null && (( i < 5 )); do
        sleep 1
        (( ++i ))   # pre-increment; post-increment returns 1 at i==0 → set -e abort (#631)
      done
      if kill -0 "$lpid" 2>/dev/null; then
        kill -KILL "$lpid" 2>/dev/null || true
      fi
      if (( nonce_verified )); then
        print "killed nonce-verified stale fishhawkd (pid ${lpid}) on port ${port} (#1018)"
      else
        print "killed stale fishhawkd squatter (pid ${lpid}) on port ${port}"
      fi
      rm -f "$pid_file"
    else
      print -u2 "error: port ${port} is still held by pid ${lpid} (${comm:t}) — not fishhawkd; refusing to report a clean shutdown"
      rc=1
    fi
  done <<< "$listeners"
  return $rc
}

# Sweep numbered duplicate pid files ('dev 2.pid' … — the shapes observed in
# #965; never dev.pid itself) so strays can't accumulate or be mistaken for
# the live pid file. Parameterized on the directory so scripts/test-dev can
# drive it against a tempdir. (N) makes the glob expand to nothing when there
# are no strays.
_clean_stray_pid_files() {
  local dir="$1"
  local f
  for f in "${dir}"/dev\ *.pid(N); do
    rm -f "$f"
    print "removed stray pid file: ${f:t}"
  done
}

# Local image tag the Docker-Desktop Kubernetes bring-up builds and the chart is
# pointed at via `--set image.tag=dev-local`. Docker Desktop's k8s shares the host
# Docker daemon image store, so a locally built image under this tag is resolvable
# in-cluster with pullPolicy: IfNotPresent — no registry push / kind load needed.
# Pure (no git/cluster), so scripts/test-dev can assert the tag directly.
_k8s_image_ref() {
  print "ghcr.io/kuhlman-labs/fishhawkd:dev-local"
}

# Health endpoint reached through the k8s port-forward. The forward maps a host
# port (arg 1, default 8080) to the in-cluster fishhawkd Service, so the URL is
# always localhost-flavored regardless of the cluster topology. Mirrors
# _healthz_url so the readiness gate stays correct if the forwarded port changes.
_k8s_healthz_url() {
  local port="${1:-8080}"
  print "http://localhost:${port}/healthz"
}

# Poll <url> until fishhawkd <pid> answers GET /healthz, for up to <deadline>
# seconds (default 10). Returns 0 on the first healthy response. Returns 1 early
# if the process has already exited (kill -0 fails — spawn-then-die fails fast
# instead of waiting the full deadline) or if the deadline elapses. Reuses the
# minio curl flags for consistency; runs the checks inside if-conditions so
# `set -e` does not abort the loop.
_await_healthz() {
  local pid="$1"
  local url="$2"
  local deadline="${3:-10}"
  local i=0
  while (( i < deadline )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 1
    fi
    if curl --silent --fail --max-time 2 "$url" &>/dev/null; then
      return 0
    fi
    sleep 1
    (( ++i ))   # pre-increment; post-increment returns 1 at i==0 → set -e abort (#631)
  done
  return 1
}

# Populates global rebuild_set: binary_name -> trigger_reason.
# trigger_reason values: "__baseline__" (fishhawkd always-on), a changed file path
# (matrix match), or unset (no trigger found for this binary).
_detect_rebuild_set() {
  # fishhawkd is always rebuilt as the baseline regardless of diff
  rebuild_set[fishhawkd]="__baseline__"

  local base_ref="origin/main"
  if ! git rev-parse --verify "$base_ref" &>/dev/null 2>&1; then
    print "warning: origin/main not available — falling back to main...HEAD"
    base_ref="main"
  fi

  local changed_files
  if ! changed_files="$(git diff --name-only "${base_ref}...HEAD" 2>/dev/null)"; then
    print "warning: git diff failed — rebuilding all binaries"
    rebuild_set[fishhawk-mcp]="__all__"
    rebuild_set[fishhawk-runner]="__all__"
    rebuild_set[fishhawk]="__all__"
    return
  fi

  [[ -z "$changed_files" ]] && return

  local f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue

    case "$f" in
      # Shared libs trigger all four binaries; short-circuit on first hit
      backend/internal/plan/*|backend/internal/spec/*)
        if [[ "${rebuild_set[fishhawkd]}" == "__baseline__" ]]; then rebuild_set[fishhawkd]="$f"; fi
        if [[ -z "${rebuild_set[fishhawk-mcp]:-}" ]];    then rebuild_set[fishhawk-mcp]="$f"; fi
        if [[ -z "${rebuild_set[fishhawk-runner]:-}" ]]; then rebuild_set[fishhawk-runner]="$f"; fi
        if [[ -z "${rebuild_set[fishhawk]:-}" ]];        then rebuild_set[fishhawk]="$f"; fi
        return
        ;;
      backend/cmd/fishhawkd/*|backend/internal/*)
        if [[ "${rebuild_set[fishhawkd]}" == "__baseline__" ]]; then rebuild_set[fishhawkd]="$f"; fi
        ;;
      backend/cmd/fishhawk-mcp/*)
        if [[ -z "${rebuild_set[fishhawk-mcp]:-}" ]]; then rebuild_set[fishhawk-mcp]="$f"; fi
        ;;
      runner/cmd/fishhawk-runner/*|runner/internal/*)
        if [[ -z "${rebuild_set[fishhawk-runner]:-}" ]]; then rebuild_set[fishhawk-runner]="$f"; fi
        ;;
      cli/cmd/fishhawk/*|cli/internal/*)
        if [[ -z "${rebuild_set[fishhawk]:-}" ]]; then rebuild_set[fishhawk]="$f"; fi
        ;;
    esac
  done <<< "$changed_files"
}

# Pure: append "-dirty" to a short SHA iff the porcelain text is non-empty.
# `git status --porcelain` emits empty output iff the working tree is clean
# (untracked files count as dirty — deliberate: they can affect the build).
# Git-free so scripts/test-dev can drive it with crafted input.
_sha_with_dirty() {
  local sha="$1"
  local porcelain="$2"
  if [[ -n "$porcelain" ]]; then
    print -r -- "${sha}-dirty"
  else
    print -r -- "$sha"
  fi
}

# Pure: map a binary name to the -ldflags string stamping GitSHA into its
# version package. CAUTION: -ldflags -X on a package path that doesn't declare
# the var is a SILENT no-op, not a build error — scripts/test-dev body-greps
# each path here against the `var GitSHA` declaration in the matching
# version.go so a package move/rename fails the suite instead of silently
# producing unstamped binaries. Git-free so scripts/test-dev can drive it.
_build_ldflags() {
  local name="$1"
  local sha="$2"
  local pkg
  case "$name" in
    fishhawkd|fishhawk-mcp) pkg="github.com/kuhlman-labs/fishhawk/backend/internal/version" ;;
    fishhawk-runner)        pkg="github.com/kuhlman-labs/fishhawk/runner/internal/version" ;;
    fishhawk)               pkg="github.com/kuhlman-labs/fishhawk/cli/internal/version" ;;
    *)                      return 1 ;;
  esac
  print -r -- "-X ${pkg}.GitSHA=${sha}"
}

# Impure: the short HEAD SHA with a -dirty suffix on a dirty tree, degrading
# to "unknown" (with a warning) when git fails. Callers cache the result in
# DEV_GIT_SHA so an up/reload pass runs git once, not once per binary.
_dev_git_sha() {
  local sha porcelain
  if ! sha="$(git -C "${REPO_ROOT}" rev-parse --short HEAD 2>/dev/null)"; then
    print -u2 "warning: git rev-parse HEAD failed — stamping GitSHA=unknown"
    print -r -- "unknown"
    return
  fi
  porcelain="$(git -C "${REPO_ROOT}" status --porcelain 2>/dev/null || true)"
  _sha_with_dirty "$sha" "$porcelain"
}

# Per-pass GitSHA cache for _build_binary (set on first build of the pass).
DEV_GIT_SHA=""

# Build one binary. Returns 1 (skipped) when source dir is absent; exits 1 on
# build failure; returns 0 and prints a status line on success.
_build_binary() {
  local name="$1"
  local trigger="$2"
  typeset -A src_paths
  src_paths=(
    fishhawkd        "./backend/cmd/fishhawkd/"
    fishhawk-mcp     "./backend/cmd/fishhawk-mcp/"
    fishhawk-runner  "./runner/cmd/fishhawk-runner/"
    fishhawk         "./cli/cmd/fishhawk/"
  )
  local src="${src_paths[$name]}"
  local src_dir="${REPO_ROOT}/${src#./}"

  if [[ ! -d "$src_dir" ]]; then
    print "warning: ${name}: source directory ${src} not found — skipping"
    return 1
  fi

  if [[ -z "$DEV_GIT_SHA" ]]; then
    DEV_GIT_SHA="$(_dev_git_sha)"
  fi
  (cd "${REPO_ROOT}" && go build -ldflags "$(_build_ldflags "$name" "$DEV_GIT_SHA")" -o "bin/${name}" "${src}") || exit 1

  case "$trigger" in
    __baseline__) print "${name}: rebuilt (baseline)" ;;
    __all__)      print "${name}: rebuilt (--all)" ;;
    *)            print "${name}: rebuilt (triggered by ${trigger})" ;;
  esac
}

# Pure path matcher: returns 0 if any line of the newline-delimited changed-file
# text in $1 matches a rebuild-matrix glob that routes to fishhawk-mcp, else 1.
# Reuses the exact glob set _detect_rebuild_set uses for fishhawk-mcp — the
# shared-lib case (backend/internal/plan|spec, line ~71) plus the mcp-cmd case
# (backend/cmd/fishhawk-mcp, line ~81). If those matrix globs change, this must
# move with them. Git-free so scripts/test-dev can drive it with crafted input.
_diff_touches_mcp() {
  local diff_text="$1"
  local f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    case "$f" in
      backend/cmd/fishhawk-mcp/*|backend/internal/plan/*|backend/internal/spec/*)
        return 0
        ;;
    esac
  done <<< "$diff_text"
  return 1
}

# Pure: extract the integer MAJOR component of the `version:` line from raw
# `.fishhawk/workflows.yaml` text. Echoes the major (the substring before the
# first '.', with surrounding quotes/whitespace stripped) or nothing when no
# `version:` line is present. Git-free so scripts/test-dev can drive it with
# crafted input, mirroring _diff_touches_mcp. Used by _workflow_major_changed
# to fire the reconnect banner on a schema-MAJOR bump (#1422) — the exact state
# change that requires the live MCP server to support the new major.
_extract_workflow_version_major() {
  local spec_text="$1"
  local line
  line="$(print -r -- "$spec_text" | grep -E '^[[:space:]]*version:' | head -n 1)"
  if [[ -z "$line" ]]; then
    return 0
  fi
  # Take everything after the first colon, strip quotes and whitespace.
  local val="${line#*:}"
  val="${val//\"/}"
  val="${val//\'/}"
  val="${val//[[:space:]]/}"
  if [[ -z "$val" ]]; then
    return 0
  fi
  # Major is the substring before the first '.' (or the whole value if none).
  print -r -- "${val%%.*}"
}

# Pure: compare the workflow-spec version MAJOR between two raw spec texts.
# Echoes 1 when the major changed (fire the reconnect banner) or 0 when it did
# not. A schema-MAJOR bump (e.g. version "0.7" -> "1.0", #1419) is precisely the
# state that breaks the loop until the live fishhawk-mcp is reconnected (#1422),
# independent of the merge-aware diff window that today suppresses the banner.
# Exactly-one-side-present (first introduction / removal of the version line)
# echoes 1 conservatively; both-empty echoes 0.
_workflow_major_changed() {
  local old_text="$1"
  local new_text="$2"
  local old_major new_major
  old_major="$(_extract_workflow_version_major "$old_text")"
  new_major="$(_extract_workflow_version_major "$new_text")"
  if [[ -z "$old_major" && -z "$new_major" ]]; then
    print 0
    return
  fi
  if [[ "$old_major" == "$new_major" ]]; then
    print 0
  else
    print 1
  fi
}

# Pure decision helper for the MCP reconnect banner — extracted so the
# branch logic is hermetically testable. The caller runs the git diff and
# passes the result in. Echoes 1 (fire the banner) or 0 (stay quiet).
# Args: <mcp_rebuilt 0|1> <force_all 0|1> <reflog_ok 0|1> <merge_diff_text> [<workflow_major_changed 0|1>]
#   - workflow major changed       -> 1 (#1422: a schema-major bump requires the
#                                        live MCP to support the new major; fires
#                                        even on a plain `up` that did not rebuild
#                                        mcp, BEFORE the mcp-not-rebuilt return)
#   - mcp not rebuilt              -> 0
#   - rebuilt under --all, reflog ok -> consult merge diff (touches mcp ? 1 : 0)
#   - rebuilt under --all, no reflog -> 1 (safe fallback; never a silent stale mcp)
#   - rebuilt under a branch-diff up -> 1 (rebuilt_list membership already means
#                                          mcp source differs from main)
_decide_mcp_signal() {
  local mcp_rebuilt="$1"
  local force_all="$2"
  local reflog_ok="$3"
  local merge_diff="$4"
  local workflow_major_changed="${5:-0}"

  # A schema-MAJOR bump (#1422) forces the banner even when mcp was not rebuilt
  # and even when the merge diff misses mcp source: the LIVE stdio MCP server
  # validates the spec locally, so a new major it doesn't recognize breaks every
  # start_run until the operator reconnects. This OR is BEFORE the
  # mcp-not-rebuilt early return on purpose.
  if (( workflow_major_changed )); then
    print 1
    return
  fi

  if (( ! mcp_rebuilt )); then
    print 0
    return
  fi

  if (( force_all )); then
    if (( reflog_ok )); then
      if _diff_touches_mcp "$merge_diff"; then
        print 1
      else
        print 0
      fi
    else
      print 1
    fi
    return
  fi

  print 1
}

# Emits the MCP reconnect signal — must be the LAST thing printed by up/reload
# so it is unmissable. Arg 1: 1 if a /mcp reconnect is required this run, else 0.
# Arg 2 (optional): the reason — "schema_major" prints a distinct, louder line
# naming the workflow-spec MAJOR bump (#1422) as the trigger; anything else (or
# unset) keeps the plain-rebuild text. scripts/dev cannot restart the MCP server
# (the Claude Code harness owns that process), so on a rebuild OR a schema-major
# bump the only lever is to tell the operator, unmissably, that a manual /mcp
# reconnect is required or the new binary / new schema major stays inert.
_signal_mcp_activation() {
  local rebuilt="${1:-0}"
  local reason="${2:-}"
  if (( rebuilt )); then
    if [[ "$reason" == "schema_major" ]]; then
      print ""
      print "################################################################"
      print "  ACTION REQUIRED: the .fishhawk/workflows.yaml schema MAJOR"
      print "  changed in this pull (#1422)."
      print ""
      print "  The LIVE fishhawk-mcp validates the spec locally. Until you"
      print "  reconnect, every fishhawk_start_run will fail against the new"
      print "  major. scripts/dev cannot restart the MCP server — the Claude"
      print "  Code harness owns that process. Run /mcp to reconnect NOW, or"
      print "  the loop stays broken in this session."
      print "################################################################"
    else
      print ""
      print "================================================================"
      print "  ACTION REQUIRED: bin/fishhawk-mcp was rebuilt this run."
      print ""
      print "  scripts/dev cannot restart the MCP server — the Claude Code"
      print "  harness owns that process. Run /mcp to reconnect, or the"
      print "  rebuilt fishhawk-mcp binary stays inert in this session."
      print "================================================================"
    fi
  else
    print "no MCP reconnect needed (bin/fishhawk-mcp unchanged)"
  fi
}

cmd_up() {
  print "up: starting"
  local force_all=0
  local start_deps=0
  for arg in "$@"; do
    if [[ "$arg" == "--all" ]]; then force_all=1; fi
    if [[ "$arg" == "--start-deps" ]]; then start_deps=1; fi
  done

  # Idempotency: bail if already running
  if [[ -f "$PID_FILE" ]]; then
    local existing_pid
    existing_pid="$(cat "$PID_FILE")"
    if kill -0 "$existing_pid" 2>/dev/null; then
      print "fishhawkd already running (pid ${existing_pid})"
      return 0
    fi
    rm -f "$PID_FILE"
  fi

  # Logs directory
  mkdir -p "$LOG_DIR"

  # Environment
  if [[ -f "${REPO_ROOT}/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "${REPO_ROOT}/.env"
    set +a
  else
    print "warning: .env not found — using current shell environment"
  fi

  # Pre-spawn port preflight (#965): a listener already on the fishhawkd port
  # means the spawn below would bind-fail and die while the squatter keeps
  # answering /healthz — the false-success shape. Fail loud, naming each
  # squatting pid and its command, before any further work. Runs after the
  # .env load so FISHHAWKD_ADDR overrides are in effect.
  local hport
  hport="$(_healthz_port)"
  if command -v lsof &>/dev/null; then
    local squatters=""
    if ! squatters="$(_port_listeners "$hport")"; then squatters=""; fi
    if [[ -n "$squatters" ]]; then
      local spid scomm sdesc=""
      while IFS= read -r spid; do
        if [[ -z "$spid" ]]; then continue; fi
        scomm="?"
        if ! scomm="$(ps -p "$spid" -o comm= 2>/dev/null)"; then scomm="?"; fi
        sdesc+="pid ${spid} (${scomm:t}) "
      done <<< "$squatters"
      _die "port ${hport} already has a listener: ${sdesc}— run 'scripts/dev down', or kill the pid, then retry"
    fi
  else
    print "warning: lsof not found — skipping port preflight and listener-identity check (degraded)"
  fi

  # TCC preflight (macOS Full Disk Access)
  if ! stat -- "${REPO_ROOT}/README.md" >/dev/null 2>/tmp/_dev_stat_err; then
    if grep -q 'Operation not permitted' /tmp/_dev_stat_err 2>/dev/null; then
      _die "no read access to the repo — grant Claude Code Full Disk Access in System Settings > Privacy & Security > Full Disk Access, then restart Claude Code"
    fi
  fi

  # Docker daemon preflight
  if ! docker info &>/dev/null 2>&1; then
    _die 'Docker daemon not running — run "open -a Docker" and wait ~20s, then retry'
  fi

  # Containers preflight — check each independently, but run docker compose up -d at most once.
  local pg_running=0 minio_running=0
  if [[ -n "$(docker ps --filter 'name=^/fishhawk-postgres$' --format '{{.Names}}')" ]]; then pg_running=1; fi
  if [[ -n "$(docker ps --filter 'name=^/fishhawk-minio$' --format '{{.Names}}')" ]]; then minio_running=1; fi

  if (( !pg_running || !minio_running )); then
    if (( start_deps )); then
      print "starting containers..."
      docker compose up -d
      local i=0
      while (( i < 30 )); do
        _pg_ready && _minio_ready && break
        sleep 2
        (( ++i ))   # pre-increment; post-increment returns 1 at i==0 → set -e abort (#631)
      done
      _pg_ready || _die "postgres did not become ready within 60s — check: docker logs fishhawk-postgres"
      _minio_ready || _die "minio did not become ready within 60s — check: docker logs fishhawk-minio"
      print "postgres: ready"
      print "minio: ready"
    else
      _die 'postgres/minio containers not up — run "docker compose up -d", then retry (or pass --start-deps)'
    fi
  else
    print "postgres: running"
    print "minio: running"
  fi

  # Build
  print "building binaries..."
  mkdir -p "${REPO_ROOT}/bin"

  typeset -gA rebuild_set

  if (( force_all )); then
    rebuild_set=(
      fishhawkd       __all__
      fishhawk-mcp    __all__
      fishhawk-runner __all__
      fishhawk        __all__
    )
  else
    _detect_rebuild_set
  fi

  local -a rebuilt_list=()
  local binary
  for binary in fishhawkd fishhawk-mcp fishhawk-runner fishhawk; do
    if [[ -n "${rebuild_set[$binary]:-}" ]]; then
      if _build_binary "$binary" "${rebuild_set[$binary]}"; then
        rebuilt_list+=("$binary")
      fi
    fi
  done

  local count=${#rebuilt_list[@]}
  if (( count > 0 )); then
    print "rebuilt ${count} of 4 binaries: ${(j:, :)rebuilt_list}"
  else
    print "rebuilt 0 of 4 binaries (nothing changed)"
  fi

  # Detect whether fishhawk-mcp was rebuilt off the existing rebuilt_list — no
  # second detection mechanism. The (Ie) subscript flags return the matching
  # index (>0) or 0 when absent.
  local mcp_rebuilt=0
  if (( ${rebuilt_list[(Ie)fishhawk-mcp]} )); then
    mcp_rebuilt=1
  fi

  # Decide the reconnect banner. Under --all (reload), fishhawk-mcp ALWAYS
  # rebuilds, so rebuilt_list membership is uninformative — keying the nag off it
  # would fire on every post-merge reload even when the merge never touched the
  # MCP server. Consult the pull's merge-aware diff (HEAD@{1}..HEAD) and fire only
  # when it actually touched fishhawk-mcp source. Quote 'HEAD@{1}' so zsh leaves
  # the brace literal; run the git call as an if-condition so set -e is suppressed
  # and an unresolvable reflog (fresh clone / detached HEAD) branches to the safe
  # fallback (fire the banner) rather than aborting cmd_up.
  local reflog_ok=0 merge_diff=""
  if merge_diff="$(git diff --name-only 'HEAD@{1}' HEAD 2>/dev/null)"; then
    reflog_ok=1
  fi

  # Schema-MAJOR bump detection (#1422): a `.fishhawk/workflows.yaml` version
  # MAJOR change breaks every fishhawk_start_run because the live stdio MCP
  # validates the spec locally on the (now stale) binary. This is independent of
  # the mcp-rebuild / merge-diff signal above — a plain `up` that rebuilt nothing
  # still needs a reconnect when the pulled spec's major moved. Read the pre-pull
  # and post-pull spec text via git show; each as an if-condition so a missing
  # file / unresolvable reflog branches to empty text (treated as no-version)
  # rather than aborting cmd_up under set -e.
  local old_spec_text="" new_spec_text=""
  if ! old_spec_text="$(git show 'HEAD@{1}:.fishhawk/workflows.yaml' 2>/dev/null)"; then old_spec_text=""; fi
  if ! new_spec_text="$(git show 'HEAD:.fishhawk/workflows.yaml' 2>/dev/null)"; then new_spec_text=""; fi
  local workflow_major_changed
  workflow_major_changed="$(_workflow_major_changed "$old_spec_text" "$new_spec_text")"

  local mcp_signal
  mcp_signal="$(_decide_mcp_signal "$mcp_rebuilt" "$force_all" "$reflog_ok" "$merge_diff" "$workflow_major_changed")"
  local mcp_reason=""
  if (( workflow_major_changed )); then mcp_reason="schema_major"; fi

  # Migrate
  print "applying migrations..."
  "$BIN" migrate up

  # Spawn. The per-spawn start nonce (#1018) is handed to the child via
  # FISHHAWKD_START_NONCE (env-prefix form scopes it to the child only) and
  # persisted to NONCE_FILE so cmd_down's port fallback can later prove a
  # stale listener is ours.
  mkdir -p "${REPO_ROOT}/.fishhawk"
  local start_nonce
  start_nonce="$(_generate_start_nonce)"
  print "$start_nonce" > "$NONCE_FILE"
  # --enable-child-completion-sweeper (#1238): the 60s fan-in backstop is OFF
  # by default in fishhawkd ("dev-loop posture"), so on the local stack a
  # decomposed parent whose children all settle would stay parked in
  # awaiting_children with no consolidated branch/PR. Re-enable it here so the
  # local runner completes decompositions automatically; scripts/test-dev
  # body-greps for this flag so a future edit can't silently drop it.
  FISHHAWKD_START_NONCE="$start_nonce" "${BIN}" serve --enable-child-completion-sweeper >> "$LOG_FILE" 2>&1 &
  local pid=$!
  disown
  print "$pid" > "$PID_FILE"
  _clean_stray_pid_files "${PID_FILE:h}"

  # Readiness gate: the spawn above is fire-and-forget — without confirming the
  # process is alive and listening, a silent no-op reads as a false 'started'
  # and only surfaces later as 'connection refused'. Poll /healthz; on timeout
  # or spawn-then-die, fail loud (log tail + non-zero exit) so reload surfaces it.
  if ! _await_healthz "$pid" "$(_healthz_url)" 10; then
    print -u2 "error: fishhawkd did not become healthy within 10s"
    print -u2 "last ${LOG_FILE} lines:"
    tail -n 15 "$LOG_FILE" >&2
    rm -f "$PID_FILE" "$NONCE_FILE"
    exit 1
  fi

  # Listener-identity check: the gate above proves the port answers and the
  # spawned pid is alive — not that the spawned pid IS the listener. Primary
  # proof is the start_nonce round-trip (#1018), which survives OS pid reuse;
  # a body without the field (pre-nonce binary) degrades with a warning to the
  # #965 pid comparison (_verify_listener_identity). A mismatch or unreachable
  # /healthz fails loud per the #628 contract.
  local nonce_rc=0
  if _verify_healthz_nonce "$(_healthz_url)" "$start_nonce" "$LOG_FILE"; then
    nonce_rc=0
  else
    nonce_rc=$?
  fi
  if (( nonce_rc == 0 )); then
    print "listener identity nonce-verified (start_nonce round-trip, #1018)"
  elif (( nonce_rc == 2 )); then
    print "warning: /healthz body carries no start_nonce (pre-#1018 fishhawkd binary?) — degrading to the #965 pid identity check"
    if ! _verify_listener_identity "$pid" "$hport" "$LOG_FILE"; then
      kill "$pid" 2>/dev/null || true
      rm -f "$PID_FILE" "$NONCE_FILE"
      exit 1
    fi
  else
    kill "$pid" 2>/dev/null || true
    rm -f "$PID_FILE" "$NONCE_FILE"
    exit 1
  fi

  print "fishhawkd started (pid ${pid}) — logs: ${LOG_FILE}"

  # Last line(s): tell the operator whether a /mcp reconnect is required. The
  # reason distinguishes a schema-MAJOR bump (#1422, louder banner) from a plain
  # rebuild.
  _signal_mcp_activation "$mcp_signal" "$mcp_reason"
}

cmd_down() {
  # .env parity with up (guarded): FISHHAWKD_ADDR may be set only in .env, and
  # the port fallback below must check the same port up's gate derives.
  if [[ -f "${REPO_ROOT}/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "${REPO_ROOT}/.env"
    set +a
  fi

  # The missing-pid-file and already-stopped paths no longer return success
  # immediately — every path falls through to the port fallback below, so
  # 'down succeeded but a daemon still serves the port' is impossible (#965).
  if [[ ! -f "$PID_FILE" ]]; then
    print "fishhawkd is not running (no pid file)"
  else
    local pid
    pid="$(cat "$PID_FILE")"

    if ! kill -0 "$pid" 2>/dev/null; then
      print "fishhawkd already stopped"
      rm -f "$PID_FILE"
    else
      kill -TERM "$pid"

      local i=0
      while kill -0 "$pid" 2>/dev/null && (( i < 5 )); do
        sleep 1
        (( ++i ))   # pre-increment; post-increment returns 1 at i==0 → set -e abort (the #631 trigger)
      done

      if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid"
        print "fishhawkd killed (SIGKILL after 5s)"
      else
        print "fishhawkd stopped"
      fi

      rm -f "$PID_FILE"
    fi
  fi

  _clean_stray_pid_files "${PID_FILE:h}"

  # Port fallback (#965): kill a stale fishhawkd squatter (orphaned by a lost
  # pid file), or report a foreign listener and refuse to claim success. The
  # nonce file lets the fallback prove a stale listener is ours (#1018), so it
  # is removed only AFTER the fallback ran — but on every teardown path.
  if ! _down_port_fallback "$(_healthz_port)" "$PID_FILE" "$NONCE_FILE"; then
    rm -f "$NONCE_FILE"
    exit 1
  fi
  rm -f "$NONCE_FILE"
}

# One-step post-merge command: stop fishhawkd (if running), rebuild ALL four
# binaries, restart fishhawkd, and emit the MCP reconnect signal. Plain `up`
# no-ops when fishhawkd is already running, so it never rebuilds after a merge;
# reload (down-then-up) closes that gap. reload forces --all because the
# post-merge `origin/main...HEAD` diff is empty (HEAD == origin/main), so the
# rebuild matrix would match nothing and silently skip runner/CLI/mcp. The MCP
# reconnect banner is decoupled from the rebuild: it consults the merge-aware
# diff (HEAD@{1}..HEAD), so a full rebuild does not false-nag a reconnect.
# Extra flags (--start-deps, a redundant --all) forward to cmd_up unchanged.
cmd_reload() {
  print "reload: starting"
  if [[ -f "$PID_FILE" ]]; then
    cmd_down
  fi
  cmd_up --all "$@"
}

# One-step post-merge walk: collapse the per-PR post-merge ritual into a single
# invocation. Fast-forward-pull main, prune the merged local branch via the
# existing scripts/cleanup-merged, optionally confirm a given issue is closed,
# then run reload LAST so its built-in /healthz readiness gate (#628 — non-zero
# exit + log tail on failure) and MCP-reconnect verdict (#612) are inherited and
# the verdict is the command's final printed line. reload is the down-then-up
# stack primitive this composes. An optional leading numeric arg is the issue
# number to confirm closed (warn-only, non-fatal); remaining flags (--start-deps,
# a redundant --all) forward to cmd_reload unchanged.
cmd_post_merge() {
  print "post-merge: starting"

  local issue=''
  if [[ "${1:-}" == <-> ]]; then
    issue="$1"
    shift
  fi

  # Sync main. --ff-only refuses a non-fast-forward merge, so a diverged local
  # main exits non-zero (ZERR trap reports the site) rather than silently landing
  # a merge commit or proceeding onto a stale tree. git pull updates the reflog,
  # so cmd_up's merge-aware HEAD@{1}..HEAD diff reflects exactly what was pulled.
  git checkout main
  git pull --ff-only origin main

  # Prune the merged branch. cleanup-merged self-fetches origin/main and deletes
  # only branches that are ancestors of origin/main, so it is safe to call
  # unconditionally and never deletes main. Reuse, do not reimplement.
  "${REPO_ROOT}/scripts/cleanup-merged"

  # Optional issue-closed confirmation. Warn-only: a not-yet-closed issue must
  # not block the local stack reload, and an absent/unauthenticated gh degrades
  # gracefully. Placed BEFORE reload so the reconnect verdict stays the last line.
  if [[ -n "$issue" ]]; then
    local state=''
    if state="$(gh issue view "$issue" --json state --jq '.state' 2>/dev/null)"; then
      if [[ "$state" != "CLOSED" ]]; then
        print -u2 "warning: issue #${issue} is ${state}, not CLOSED"
      else
        print "issue #${issue}: closed"
      fi
    else
      print -u2 "warning: could not confirm issue #${issue} state (gh unavailable or unauthenticated)"
    fi
  fi

  # reload LAST: forces --all, gates the spawn on _await_healthz (log tail +
  # exit 1 on failure), and prints the MCP reconnect verdict as its final line.
  cmd_reload "$@"
}

# Local Kubernetes bring-up against Docker Desktop's cluster. Builds the
# fishhawkd image into the host Docker daemon (which Docker-Desktop k8s shares,
# so no registry push / kind load), helm-installs the chart with values-local
# overriding the image to the local build, waits for the rollout, then opens a
# port-forward and gates on /healthz — the authoritative readiness signal
# (rollout status can report available before the post-install migrate Job
# finishes; fishhawkd only answers healthy after its own startup completes).
# Fails loud (kubectl logs + pods tail, non-zero exit) on a stuck rollout or a
# /healthz timeout, mirroring cmd_up's readiness-gate contract. This is the
# operator smoke test for the chart — not exercised in CI (no cluster).
# After fishhawkd is healthy, if the dev-only in-cluster Jaeger is present
# (values-local enables it), also opens a forward for its UI (16686) + OTLP HTTP
# (4318) so the host-spawned runner can emit spans to localhost:4318.
cmd_k8s_up() {
  print "k8s: starting"
  local pf_port=8080

  print "building image $(_k8s_image_ref)..."
  (cd "${REPO_ROOT}" && docker build --build-arg GIT_SHA="$(_dev_git_sha)" -t "$(_k8s_image_ref)" -f backend/Dockerfile .)

  print "helm upgrade --install fishhawk..."
  helm upgrade --install fishhawk "${REPO_ROOT}/deploy/helm/fishhawk" \
    -f "${REPO_ROOT}/deploy/helm/fishhawk/values-local.yaml" \
    --set image.tag=dev-local \
    --set image.pullPolicy=IfNotPresent

  print "waiting for rollout..."
  # Catch the rollout failure ourselves: a stuck/CrashLoopBackOff pod makes
  # `kubectl rollout status` exit non-zero, which would otherwise trip set -e
  # and abort before any diagnostics ran. Tail pods + logs to stderr first so
  # the rollout leg honors the same fail-loud contract as the /healthz leg.
  if ! kubectl rollout status deployment/fishhawk --timeout=120s; then
    print -u2 "error: deployment/fishhawk rollout did not complete within 120s"
    print -u2 "recent pod state + logs:"
    kubectl get pods >&2 || true
    kubectl logs deploy/fishhawk --tail=20 >&2 || true
    exit 1
  fi

  # Port-forward in the background; track its pid in a named file (mirrors
  # PID_FILE) so cmd_k8s_down kills exactly this process, never an unrelated
  # forward. The forward stays in the foreground for its lifetime, so the
  # _await_healthz `kill -0` check fails fast if it dies mid-poll.
  mkdir -p "${REPO_ROOT}/.fishhawk"
  kubectl port-forward "svc/fishhawk" "${pf_port}:8080" >/dev/null 2>&1 &
  local pf_pid=$!
  disown
  print "$pf_pid" > "$K8S_PF_PID_FILE"

  if ! _await_healthz "$pf_pid" "$(_k8s_healthz_url "$pf_port")" 60; then
    print -u2 "error: fishhawkd did not become healthy within 60s"
    print -u2 "recent pod state + logs:"
    kubectl get pods >&2 || true
    kubectl logs deploy/fishhawk --tail=20 >&2 || true
    kill "$pf_pid" 2>/dev/null || true
    rm -f "$K8S_PF_PID_FILE"
    exit 1
  fi

  print "fishhawkd reachable at $(_k8s_healthz_url "$pf_port") (port-forward pid ${pf_pid})"

  # Jaeger trace-collector forward (dev-only; values-local enables jaeger). The
  # spans come from fishhawk-runner, which fishhawk-mcp spawns on THIS host
  # (inheriting its env) — not in-cluster — so the runner reaches the in-cluster
  # collector at localhost:4318 through this forward, and the UI is at
  # localhost:16686 over the same forward. One kubectl process forwards both
  # ports; its pid is tracked in K8S_JAEGER_PF_PID_FILE so k8s-down kills exactly
  # this forward. Guarded on the Service existing so a jaeger-disabled override
  # is a clean skip.
  if kubectl get svc fishhawk-jaeger >/dev/null 2>&1; then
    kubectl port-forward "svc/fishhawk-jaeger" 16686:16686 4318:4318 >/dev/null 2>&1 &
    local jaeger_pf_pid=$!
    disown
    print "$jaeger_pf_pid" > "$K8S_JAEGER_PF_PID_FILE"
    print "jaeger UI at http://localhost:16686, OTLP HTTP at http://localhost:4318 (port-forward pid ${jaeger_pf_pid})"
    print "  to capture runner spans, set OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 on this host (unset = no-op)"
  fi
}

# Tear down the local k8s deployment: kill the tracked port-forward, then
# helm-uninstall the release. Both steps are idempotent — a missing pid file or
# an already-uninstalled release ('release: not found') is a no-op — so a double
# teardown is harmless.
cmd_k8s_down() {
  if [[ -f "$K8S_PF_PID_FILE" ]]; then
    local pf_pid
    pf_pid="$(cat "$K8S_PF_PID_FILE")"
    if kill -0 "$pf_pid" 2>/dev/null; then
      kill "$pf_pid" 2>/dev/null || true
      print "port-forward stopped (pid ${pf_pid})"
    fi
    rm -f "$K8S_PF_PID_FILE"
  fi

  # Tear down the jaeger forward too (only present when jaeger was enabled).
  if [[ -f "$K8S_JAEGER_PF_PID_FILE" ]]; then
    local jaeger_pf_pid
    jaeger_pf_pid="$(cat "$K8S_JAEGER_PF_PID_FILE")"
    if kill -0 "$jaeger_pf_pid" 2>/dev/null; then
      kill "$jaeger_pf_pid" 2>/dev/null || true
      print "jaeger port-forward stopped (pid ${jaeger_pf_pid})"
    fi
    rm -f "$K8S_JAEGER_PF_PID_FILE"
  fi

  # Only an absent release is a no-op. Capture stderr so a genuine failure
  # (unreachable cluster, bad kubeconfig, permission denied) is surfaced and
  # exits non-zero, never misreported as a harmless 'nothing to uninstall'.
  local uninstall_out
  if uninstall_out="$(helm uninstall fishhawk 2>&1)"; then
    print "helm release fishhawk uninstalled"
  elif print -r -- "$uninstall_out" | grep -qi 'not found'; then
    print "helm release fishhawk not found (nothing to uninstall)"
  else
    print -u2 "error: helm uninstall fishhawk failed:"
    print -u2 -- "$uninstall_out"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Acceptance preview (E31.18 / #1569): `scripts/dev preview [<sha-or-ref>]`
# builds the run's merge candidate in a detached worktree and serves it on its
# own port against an isolated database, so the acceptance agent validates the
# PR branch instead of the orchestrating fishhawkd's main build. The runner's
# FISHHAWK_ACCEPTANCE_PREVIEW_CMD hook invokes it bare (the SHA arrives via
# FISHHAWK_PREVIEW_SHA); FISHHAWK_ACCEPTANCE_PREVIEW_TEARDOWN_CMD invokes
# `scripts/dev preview-down`.
# ---------------------------------------------------------------------------

# Pure: the isolated preview database name — the base URL's database name with
# an `_preview` suffix, so it can NEVER equal (and thus never destroy) the dev
# database. Non-zero with no output when the URL carries no database name.
# Git-free/env-free so scripts/test-dev can drive it with crafted input.
_preview_db_name() {
  local url="$1"
  local base="${url%%\?*}"      # drop ?query
  local rest="${base#*://}"     # drop scheme, so :// can't satisfy the / check
  if [[ "$rest" != */* ]]; then
    return 1
  fi
  local dbname="${rest##*/}"
  if [[ -z "$dbname" ]]; then
    return 1
  fi
  print -r -- "${dbname}_preview"
}

# Pure: the base database URL with its database name swapped for the
# _preview-suffixed one, query string preserved. Non-zero when the URL
# carries no database name (mirrors _preview_db_name).
_preview_db_url() {
  local url="$1"
  local base="${url%%\?*}"
  local query=""
  if [[ "$url" == *\?* ]]; then query="?${url#*\?}"; fi
  local dbname
  if ! dbname="$(_preview_db_name "$url")"; then
    return 1
  fi
  print -r -- "${base%/*}/${dbname}${query}"
}

# Preview listen address / port / healthz URL, from FISHHAWK_PREVIEW_ADDR
# (default localhost:8090 — deliberately distinct from the orchestrating
# fishhawkd's 8080). Mirrors the _healthz_port/_healthz_url derivation.
_preview_addr() {
  print -r -- "${FISHHAWK_PREVIEW_ADDR:-localhost:8090}"
}

_preview_port() {
  local addr
  addr="$(_preview_addr)"
  local port="${addr##*:}"
  if [[ -z "$port" || "$port" == "$addr" ]]; then port=8090; fi
  print "$port"
}

_preview_healthz_url() {
  print "http://localhost:$(_preview_port)/healthz"
}

# Extract the git_sha value from a /healthz JSON body; prints the sha or
# nothing when the field is absent. Same compact Go-marshaled `"key":"value"`
# shape (and the same always-return-0 contract) as _nonce_from_healthz_body.
_git_sha_from_healthz_body() {
  local body="$1"
  local match=""
  if match="$(print -r -- "$body" | grep -Eo '"git_sha":"[^"]*"' | head -n 1)"; then
    print -r -- "$match" | cut -d'"' -f4
  fi
}

# Poll <url> until fishhawkd <pid> answers GET /healthz with git_sha exactly
# <want> (the stamped short SHA — the build-identity readiness gate; the
# runner's probeTargetIdentity then verifies the same value against the full
# expected head SHA), for up to <deadline> seconds. Returns 1 early if the
# process died, or when the deadline elapses without an identity match — a
# healthy body with the WRONG git_sha keeps polling, so a slow-to-exit prior
# listener can't fail the gate spuriously. #631 discipline: every check runs
# in a tested context.
_await_preview_healthz() {
  local pid="$1"
  local url="$2"
  local want="$3"
  local deadline="${4:-30}"
  local i=0 body="" got=""
  while (( i < deadline )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 1
    fi
    if body="$(curl --silent --fail --max-time 2 "$url" 2>/dev/null)"; then
      got="$(_git_sha_from_healthz_body "$body")"
      if [[ -n "$got" && "$got" == "$want" ]]; then
        return 0
      fi
    fi
    sleep 1
    (( ++i ))   # pre-increment; post-increment returns 1 at i==0 → set -e abort (#631)
  done
  return 1
}

# DROP/CREATE the preview database at every preview start — deterministic
# isolation: PR-branch migrations run only ever against a throwaway database,
# never the dev one. WITH (FORCE) (postgres 13+; the dev compose pins 16)
# terminates any straggler connection from a just-killed prior preview.
# Statements run against the BASE database URL (you cannot drop the database
# you are connected to). Prefers a host psql; degrades to psql inside the
# fishhawk-postgres compose container when the host has none.
_preview_db_reset() {
  local base_url="$1"
  local preview_db="$2"
  local drop_sql="DROP DATABASE IF EXISTS \"${preview_db}\" WITH (FORCE)"
  local create_sql="CREATE DATABASE \"${preview_db}\""
  if command -v psql &>/dev/null; then
    psql "$base_url" -v ON_ERROR_STOP=1 -q -c "$drop_sql" -c "$create_sql"
  else
    docker exec fishhawk-postgres psql "$base_url" -v ON_ERROR_STOP=1 -q -c "$drop_sql" -c "$create_sql"
  fi
}

# TERM→5s→KILL the pid tracked in <pid_file>, then remove the file. Idempotent:
# a missing file or an already-dead pid is a clean no-op. Parameterized on the
# pid file so scripts/test-dev can drive it against a tempdir fixture.
_preview_kill_tracked() {
  local pid_file="$1"
  if [[ ! -f "$pid_file" ]]; then
    print "preview fishhawkd is not running (no pid file)"
    return 0
  fi
  local pid
  pid="$(cat "$pid_file")"
  if ! kill -0 "$pid" 2>/dev/null; then
    print "preview fishhawkd already stopped"
    rm -f "$pid_file"
    return 0
  fi
  kill -TERM "$pid" 2>/dev/null || true
  local i=0
  while kill -0 "$pid" 2>/dev/null && (( i < 5 )); do
    sleep 1
    (( ++i ))   # pre-increment; post-increment returns 1 at i==0 → set -e abort (#631)
  done
  if kill -0 "$pid" 2>/dev/null; then
    kill -KILL "$pid" 2>/dev/null || true
    print "preview fishhawkd killed (SIGKILL after 5s)"
  else
    print "preview fishhawkd stopped"
  fi
  rm -f "$pid_file"
}

# Remove the preview worktree at <dir>. `git worktree remove --force` handles
# the registered case; an unregistered leftover directory (or a repo state git
# refuses to touch) degrades to rm -rf — the path is our own fixed
# .fishhawk/preview-worktree, never operator data. Prune afterwards so a stale
# registration can't block the next `git worktree add`. Idempotent.
_preview_remove_worktree() {
  local dir="$1"
  if [[ ! -d "$dir" ]]; then
    git -C "${REPO_ROOT}" worktree prune 2>/dev/null || true
    return 0
  fi
  if git -C "${REPO_ROOT}" worktree remove --force "$dir" 2>/dev/null; then
    print "preview worktree removed"
  else
    rm -rf "$dir"
    print "preview worktree removed (rm -rf fallback)"
  fi
  git -C "${REPO_ROOT}" worktree prune 2>/dev/null || true
}

# `scripts/dev preview [<sha-or-ref>]` — build and serve the merge candidate.
# The positional arg defaults to $FISHHAWK_PREVIEW_SHA so the runner's
# provisioning hook can invoke the command bare.
cmd_preview() {
  print "preview: starting"

  # Environment (same posture as cmd_up): FISHHAWKD_DATABASE_URL and the
  # FISHHAWK_PREVIEW_* overrides may live only in .env.
  if [[ -f "${REPO_ROOT}/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "${REPO_ROOT}/.env"
    set +a
  else
    print "warning: .env not found — using current shell environment"
  fi

  local ref="${1:-${FISHHAWK_PREVIEW_SHA:-}}"
  if [[ -z "$ref" ]]; then
    _die "no SHA to preview — pass one (scripts/dev preview <sha-or-ref>) or set FISHHAWK_PREVIEW_SHA"
  fi
  local base_url="${FISHHAWKD_DATABASE_URL:-}"
  if [[ -z "$base_url" ]]; then
    _die "FISHHAWKD_DATABASE_URL is not set — the preview needs it to derive its isolated _preview database"
  fi
  local preview_db="" preview_url=""
  if ! preview_db="$(_preview_db_name "$base_url")"; then
    _die "FISHHAWKD_DATABASE_URL carries no database name — cannot derive the _preview database"
  fi
  preview_url="$(_preview_db_url "$base_url")"

  # Fetch, then resolve the ref. A PR-head SHA may not be reachable from any
  # already-fetched branch, so an unresolved ref gets one direct-fetch retry
  # before failing. Offline fetch degrades with a warning — the ref may
  # already be local.
  if ! git -C "${REPO_ROOT}" fetch origin --quiet 2>/dev/null; then
    print "warning: git fetch origin failed — resolving ${ref} against local objects only"
  fi
  local sha=""
  if ! sha="$(git -C "${REPO_ROOT}" rev-parse --verify --quiet "${ref}^{commit}")"; then
    if git -C "${REPO_ROOT}" fetch origin "$ref" --quiet 2>/dev/null; then
      sha="$(git -C "${REPO_ROOT}" rev-parse --verify --quiet "${ref}^{commit}")" || sha=""
    fi
  fi
  if [[ -z "$sha" ]]; then
    _die "could not resolve '${ref}' to a commit (after git fetch origin) — is the run branch pushed?"
  fi
  local short_sha
  short_sha="$(git -C "${REPO_ROOT}" rev-parse --short "$sha")"

  # Deterministic restart: tear down any prior preview (tracked pid + worktree)
  # before this one — the runner hook re-provisions per acceptance stage.
  _preview_kill_tracked "$PREVIEW_PID_FILE"
  _preview_remove_worktree "$PREVIEW_WORKTREE"

  # Port preflight (#965 posture): a foreign listener on the preview port means
  # the spawn below would bind-fail while the squatter answers the readiness
  # probe with the wrong (or right!) identity. Fail loud before any work.
  local pport
  pport="$(_preview_port)"
  if command -v lsof &>/dev/null; then
    local squatters=""
    if ! squatters="$(_port_listeners "$pport")"; then squatters=""; fi
    if [[ -n "$squatters" ]]; then
      local spid scomm sdesc=""
      while IFS= read -r spid; do
        if [[ -z "$spid" ]]; then continue; fi
        scomm="?"
        if ! scomm="$(ps -p "$spid" -o comm= 2>/dev/null)"; then scomm="?"; fi
        sdesc+="pid ${spid} (${scomm:t}) "
      done <<< "$squatters"
      _die "preview port ${pport} already has a listener: ${sdesc}— run 'scripts/dev preview-down', or kill the pid, then retry"
    fi
  else
    print "warning: lsof not found — skipping preview port preflight (degraded)"
  fi

  # Detached preview worktree at the merge candidate. A clean detached
  # checkout, so the GitSHA stamp below carries no -dirty suffix — a dirty
  # stamp would (correctly) fail the runner's fail-closed staleness probe.
  mkdir -p "${PREVIEW_WORKTREE:h}"
  print "preview: adding worktree at ${short_sha}..."
  git -C "${REPO_ROOT}" worktree add --quiet --detach "$PREVIEW_WORKTREE" "$sha"

  # Build fishhawkd from the preview tree, stamped with the preview SHA via
  # the same _build_ldflags path the dev build uses (#1007). The binary lands
  # inside the worktree so preview-down's removal cleans it up.
  print "preview: building fishhawkd (GitSHA=${short_sha})..."
  local pbin="${PREVIEW_WORKTREE}/bin/fishhawkd"
  if ! (cd "$PREVIEW_WORKTREE" && mkdir -p bin && go build -ldflags "$(_build_ldflags fishhawkd "$short_sha")" -o bin/fishhawkd ./backend/cmd/fishhawkd/); then
    print -u2 "error: preview fishhawkd build failed at ${short_sha}"
    _preview_remove_worktree "$PREVIEW_WORKTREE"
    exit 1
  fi

  # Isolated database: DROP/CREATE <dbname>_preview, then run the PREVIEW
  # binary's migrations against it — PR-branch migrations never touch the dev
  # database.
  print "preview: resetting database ${preview_db}..."
  if ! _preview_db_reset "$base_url" "$preview_db"; then
    print -u2 "error: could not DROP/CREATE ${preview_db} — is postgres up (docker compose up -d)?"
    _preview_remove_worktree "$PREVIEW_WORKTREE"
    exit 1
  fi
  print "preview: applying migrations..."
  if ! FISHHAWKD_DATABASE_URL="$preview_url" "$pbin" migrate up; then
    print -u2 "error: preview migrations failed against ${preview_db}"
    _preview_remove_worktree "$PREVIEW_WORKTREE"
    exit 1
  fi

  # Spawn on the preview address and gate readiness on /healthz echoing the
  # stamped git_sha — serving is not enough; the listener must BE the merge
  # candidate (the same identity the runner's probe then re-verifies).
  local paddr
  paddr="$(_preview_addr)"
  mkdir -p "$LOG_DIR"
  FISHHAWKD_DATABASE_URL="$preview_url" FISHHAWKD_ADDR="$paddr" "$pbin" serve >> "$PREVIEW_LOG_FILE" 2>&1 &
  local pid=$!
  disown
  print "$pid" > "$PREVIEW_PID_FILE"

  if ! _await_preview_healthz "$pid" "$(_preview_healthz_url)" "$short_sha" 30; then
    print -u2 "error: preview fishhawkd did not serve git_sha=${short_sha} on $(_preview_healthz_url) within 30s"
    print -u2 "last ${PREVIEW_LOG_FILE} lines:"
    tail -n 15 "$PREVIEW_LOG_FILE" >&2
    _preview_kill_tracked "$PREVIEW_PID_FILE"
    _preview_remove_worktree "$PREVIEW_WORKTREE"
    exit 1
  fi

  print "preview fishhawkd started (pid ${pid}, git_sha ${short_sha}) on ${paddr} — db ${preview_db}, logs: ${PREVIEW_LOG_FILE}"
}

# `scripts/dev preview-down` — TERM→KILL the tracked preview daemon, remove
# the preview worktree (and the binary inside it), drop the pid file. The
# preview database is left in place; the next preview start DROP/CREATEs it.
cmd_preview_down() {
  _preview_kill_tracked "$PREVIEW_PID_FILE"
  _preview_remove_worktree "$PREVIEW_WORKTREE"
}

_usage() {
  print -u2 "usage: scripts/dev <up [--all] [--start-deps]|reload [--all] [--start-deps]|post-merge [<issue>] [--start-deps]|preview [<sha-or-ref>]|preview-down|k8s|k8s-down|down>"
  print -u2 ""
  print -u2 "  post-merge runs the full per-PR post-merge walk: git pull --ff-only,"
  print -u2 "  scripts/cleanup-merged, an optional issue-closed check (<issue>), then"
  print -u2 "  reload (whose /healthz gate + MCP reconnect verdict are inherited)."
  print -u2 ""
  print -u2 "  reload is the down-then-up stack primitive post-merge composes; plain up"
  print -u2 "  no-ops when fishhawkd is already running and so never rebuilds."
  print -u2 ""
  print -u2 "  preview builds fishhawkd from <sha-or-ref> (default \$FISHHAWK_PREVIEW_SHA) in"
  print -u2 "  a detached worktree, serves it on FISHHAWK_PREVIEW_ADDR (default"
  print -u2 "  localhost:8090) against an isolated <dbname>_preview database, and gates"
  print -u2 "  readiness on /healthz echoing the stamped git_sha; preview-down tears it"
  print -u2 "  down. This is the acceptance-stage provisioning hook (E31.18 / #1569)."
  print -u2 ""
  print -u2 "  k8s builds the fishhawkd image, helm-installs the chart with values-local"
  print -u2 "  against the Docker-Desktop cluster, and gates on /healthz; k8s-down kills"
  print -u2 "  the port-forward and helm-uninstalls. See docs/deploy/kubernetes.md."
  print -u2 ""
  print -u2 "binary activation after a rebuild:"
  print -u2 "  fishhawkd        rebuilt + restarted by up/reload"
  print -u2 "  fishhawk-runner  picked up automatically (spawned fresh from bin/ per stage)"
  print -u2 "  fishhawk-mcp     rebuilt on disk but requires a manual /mcp reconnect"
}

# DEV_LIB_ONLY lets scripts/test-dev source this file to unit-test the helpers
# without triggering the dispatch (and thus the stack).
if [[ -z "${DEV_LIB_ONLY:-}" ]]; then
  case "$cmd" in
    up)         cmd_up "${@:2}" ;;
    reload)     cmd_reload "${@:2}" ;;
    post-merge) cmd_post_merge "${@:2}" ;;
    preview)      cmd_preview "${@:2}" ;;
    preview-down) cmd_preview_down ;;
    k8s)        cmd_k8s_up "${@:2}" ;;
    k8s-down)   cmd_k8s_down ;;
    down)       cmd_down ;;
    *)          _usage; exit 1 ;;
  esac
fi
