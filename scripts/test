#!/usr/bin/env bash
# scripts/test — wraps the multi-module Go test + coverage gates.
#
# Mirrors the loop CI uses for the Go lane: reads registered modules
# from go.work, runs each module's tests in its own directory.
# Fail-fast on the first module whose tests fail.
#
# Usage:
#   scripts/test              run `go test -race ./...` in every module
#   scripts/test coverage     the gate above + scripts/check-coverage.py
#   scripts/test lint         run `golangci-lint run ./...` in every module
#   scripts/test verify       lint + tests (no coverage) — the runner's gate
#   scripts/test single ARGS  pass-through to `go test -race ARGS`
#                             example:
#                             scripts/test single -run TestX ./backend/internal/version/...
#
# Frontend gates (pnpm format:check / typecheck / test) are NOT
# covered here — they have their own conventions per docs/.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Signing-agnostic isolation (#912): make every test that creates a temp repo
# and commits ignore the operator's global/system git config. Otherwise a
# global commit.gpgsign=true is inherited and red-lines the verify gate when
# the external signing agent (e.g. 1Password op-ssh-sign) is unavailable.
# Exported once here, so go test and its exec.Command("git", ...) children
# inherit it via os.Environ(). In-repo git ops are unaffected: the repo-local
# .git/config commit.gpgsign=false takes precedence over the now-absent global.
export GIT_CONFIG_GLOBAL=/dev/null
export GIT_CONFIG_SYSTEM=/dev/null

# Disable the testcontainers ryuk reaper (#972 cascade). It is a SHARED, single-
# point-of-failure container: under Docker-daemon load the reaper itself times
# out starting ("reaper: new reaper: run container: ... context deadline
# exceeded"), and every package that then tries to register with the dead reaper
# fails ("No such container: <reaper-id>"), cascading one flake into a whole-
# suite red. Disabling ryuk removes that shared dependency so a slow container
# start can at worst flake ONE package (which the runner's verify gate absorbs),
# never the cascade. Disabling ryuk is also what lets the single shared
# fishhawk-test-postgres container (internal/pgtest, #1174) PERSIST across the
# per-package test processes that reuse it — it is reaped by the EXIT trap below
# instead of by ryuk. (The exempt internal/postgres MigrateUp/MigrateDown tests
# still Terminate their own random-named throwaway containers via t.Cleanup.)
# Both CI runners and `scripts/dev` are ephemeral / pruned, so orphan reaping is
# not relied upon. Covers the runner's `scripts/test verify` too, since it
# sources this script.
export TESTCONTAINERS_RYUK_DISABLED=true

# Best-effort teardown of the shared testcontainers Postgres (#1174). internal/
# pgtest deliberately does NOT Terminate fishhawk-test-postgres (it is reused
# across every package's test process while ryuk is disabled above), so reap it
# here once the run is done. The test/coverage paths register this as an EXIT
# trap so it also fires on a fail-fast exit. Guarded to be a no-op when Docker
# is absent and to never fail the run.
_reap_shared_container() {
  command -v docker >/dev/null 2>&1 || return 0
  docker rm -f fishhawk-test-postgres >/dev/null 2>&1 || true
}

modules() {
  go work edit -json | jq -r '.Use[].DiskPath'
}

# Full-suite test-binary parallelism (#972, #1174). Historically every backend
# package started its OWN testcontainers Postgres, so at the default -p
# (~GOMAXPROCS) a developer-Mac Docker daemon intermittently timed out starting
# one ("context deadline exceeded" after 9 retries against docker.sock) — pure
# load contention, not a real bug — and the bound was lowered 4 -> 2 to halve
# concurrent container starts.
#
# As of #1174 the backend integration tests share a SINGLE Postgres container
# (internal/pgtest): the first package to need it starts fishhawk-test-postgres,
# every other package attaches to it by name (testcontainers WithReuseByName),
# and each test gets a cheap per-test database cloned from a migrated template.
# There is no longer a container start per package, so the start-contention that
# forced -p 2 is gone — concurrent first-starts converge to the one shared
# container via pgtest's bounded attach-retry on the docker name conflict.
# Restored 2 -> 4 (#1174), proven by a full -p 4 run showing exactly one
# fishhawk-test-postgres via `docker ps`. `go test -p n` still caps concurrent
# test binaries; lower it on a constrained daemon with FISHHAWK_TEST_P (e.g.
# FISHHAWK_TEST_P=2). `single` runs are unbounded.
TEST_P="${FISHHAWK_TEST_P:-4}"

cmd_test() {
  trap _reap_shared_container EXIT
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && go test -race -p "$TEST_P" ./...)
  done < <(modules)
}

cmd_coverage() {
  trap _reap_shared_container EXIT
  local profiles=()
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && go test -race -p "$TEST_P" -coverprofile=coverage.out -covermode=atomic ./...)
    profiles+=("$m/coverage.out")
  done < <(modules)
  python3 "$ROOT/scripts/check-coverage.py" --threshold 80 --exclude '/db/' "${profiles[@]}"
}

# Fail CLOSED if golangci-lint is missing: the verify gate must never silently
# skip lint and re-open the gofmt/lint-drift-to-CI gap (#1064). Name the v2.x
# install pin (the v2.8.0 install.sh tag CI uses, per AGENTS.md / ci.yml) so the
# error is actionable. A v1 binary rejects this repo's v2-format .golangci.yml,
# so v2.x is required.
_require_golangci_lint() {
  if ! command -v golangci-lint >/dev/null 2>&1; then
    cat >&2 <<'EOF'
scripts/test: golangci-lint not found on PATH (required for `lint`/`verify`).
Install golangci-lint v2.x (this repo's .golangci.yml is v2-format; v1 rejects it):
  curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/v2.8.0/install.sh \
    | sh -s -- -b "$(go env GOPATH)/bin" v2.8.0
EOF
    exit 1
  fi
}

cmd_lint() {
  _require_golangci_lint
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && golangci-lint run ./...)
  done < <(modules)
}

# verify: the runner's committed-tree implement gate. Lint FIRST so a fast
# format/lint failure leads the captured output and aborts (set -e) before the
# slow test loop. Coverage is intentionally omitted to bound in-loop runtime —
# it stays on `coverage` and in CI.
cmd_verify() {
  cmd_lint
  cmd_test
}

cmd_single() {
  if [ "$#" -eq 0 ]; then
    cat >&2 <<'EOF'
usage: scripts/test single <args>
example: scripts/test single -run TestNotifyPlanReady ./backend/internal/issuecomment/...
EOF
    exit 1
  fi
  go test -race "$@"
}

usage() {
  cat <<'EOF'
usage: scripts/test [SUBCOMMAND] [ARGS]

  test                 (default) run `go test -race ./...` in every module
  coverage             run tests + aggregate coverage gate
  lint                 run `golangci-lint run ./...` in every module
  verify               lint + tests (no coverage) — the runner's verify gate
  single ARGS          pass-through to `go test -race ARGS`
  -h | --help | help   show this message
EOF
}

case "${1:-test}" in
  test|"")          cmd_test ;;
  coverage|cover)   cmd_coverage ;;
  lint)             cmd_lint ;;
  verify)           cmd_verify ;;
  single)           shift; cmd_single "$@" ;;
  -h|--help|help)   usage ;;
  *)
    echo "scripts/test: unknown subcommand: $1" >&2
    usage >&2
    exit 1
    ;;
esac
