#!/usr/bin/env bash
# scripts/test — wraps the multi-module Go test + coverage gates.
#
# Mirrors the loop CI uses for the Go lane: reads registered modules
# from go.work, runs each module's tests in its own directory.
# Fail-fast on the first module whose tests fail.
#
# Usage:
#   scripts/test              run `go test -race ./...` in every module
#   scripts/test coverage     the gate above + scripts/check-coverage.py
#   scripts/test lint         run `golangci-lint run ./...` in every module
#   scripts/test verify       lint + schema-sync + tests (no coverage) — the runner's gate
#   scripts/test single ARGS  pass-through to `go test -race ARGS`
#                             example:
#                             scripts/test single -run TestX ./backend/internal/version/...
#
# Frontend gates (pnpm format:check / typecheck / test) are NOT
# covered here — they have their own conventions per docs/.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Signing-agnostic isolation (#912): make every test that creates a temp repo
# and commits ignore the operator's global/system git config. Otherwise a
# global commit.gpgsign=true is inherited and red-lines the verify gate when
# the external signing agent (e.g. 1Password op-ssh-sign) is unavailable.
# Exported once here, so go test and its exec.Command("git", ...) children
# inherit it via os.Environ(). In-repo git ops are unaffected: the repo-local
# .git/config commit.gpgsign=false takes precedence over the now-absent global.
export GIT_CONFIG_GLOBAL=/dev/null
export GIT_CONFIG_SYSTEM=/dev/null

# Disable the testcontainers ryuk reaper (#972 cascade). It is a SHARED, single-
# point-of-failure container: under Docker-daemon load the reaper itself times
# out starting ("reaper: new reaper: run container: ... context deadline
# exceeded"), and every package that then tries to register with the dead reaper
# fails ("No such container: <reaper-id>"), cascading one flake into a whole-
# suite red. Disabling ryuk removes that shared dependency so a slow container
# start can at worst flake ONE package (which the runner's verify gate absorbs),
# never the cascade. Disabling ryuk is also what lets the single shared
# fishhawk-test-postgres container (internal/pgtest, #1174) PERSIST across the
# per-package test processes that reuse it — it is reaped by the EXIT trap below
# instead of by ryuk. (The exempt internal/postgres MigrateUp/MigrateDown tests
# still Terminate their own random-named throwaway containers via t.Cleanup.)
# Both CI runners and `scripts/dev` are ephemeral / pruned, so orphan reaping is
# not relied upon. Covers the runner's `scripts/test verify` too, since it
# sources this script.
export TESTCONTAINERS_RYUK_DISABLED=true

# Concurrent-invocation lease refcount for the shared testcontainers Postgres
# (#1174 reuse design, #1792 collision fix). internal/pgtest deliberately does
# NOT Terminate fishhawk-test-postgres (it is reused across every package's test
# process while ryuk is disabled above), so scripts/test reaps it via the EXIT
# trap below. That was safe for concurrent PROCESSES within one invocation but
# NOT for concurrent INVOCATIONS: a first invocation's EXIT trap would docker-rm
# the shared container out from under a second invocation whose go test loop
# still held live connections (the #1587/#1589 spurious verify failure).
#
# Fix: lease-count the container across concurrent scripts/test invocations.
# Each container-using invocation registers a per-invocation lease file (named
# by its PID) in a shared lease directory under a mkdir-based lock; the EXIT
# trap removes only its OWN lease and docker-rm's the container only when no
# leases remain (rmdir of the now-empty lease dir succeeds). Stale leases left
# by a SIGKILL'd invocation are pruned by a `kill -0` PID liveness check so a
# crashed run never permanently pins the container. LEASE_DIR / LEASE_TOKEN are
# overridable to make the refcount contract hermetically testable
# (scripts/test-container-lease).
LEASE_DIR="${FISHHAWK_TEST_LEASE_DIR:-${TMPDIR:-/tmp}/fishhawk-test-postgres.leases}"

# _lease_token: this invocation's lease identity (its PID by default). Injectable
# so the hermetic test can register/reap distinct synthetic leases.
_lease_token() {
  printf '%s' "${FISHHAWK_TEST_LEASE_TOKEN:-$$}"
}

# _lease_lock: acquire the lock guarding the register/reap critical sections.
# The lock is an atomically-created SYMLINK whose target IS the holder's owner
# PID, so it carries its owner from the instant it exists: symlink(2) is a single
# atomic syscall that fails EEXIST if the path is already taken, and there is NO
# separate stamp step. Exactly one racer wins; the loser reads the winner's PID
# via `readlink`. Before each retry the spin loop breaks a lock whose owner PID
# is dead (`kill -0` fails → rm, then retry) so a SIGKILL'd holder can never
# permanently wedge later invocations.
#
# Because acquisition is atomic there is NO window in which the lock exists yet
# is unowned. That eliminates BY CONSTRUCTION both the old mkdir-then-stamp lock's
# ownerless-forever wedge (a holder SIGKILL'd between mkdir and stamping) AND its
# live-but-delayed acquisition race (a live holder paused before stamping whose
# "ownerless" lock a concurrent breaker could remove and then double-enter the
# critical section, #1792 fixup). A grace-window heuristic could only trade those
# two off; the symlink carries its owner atomically so a live holder's lock can
# never be seen as ownerless and broken out from under it. An empty/garbage link
# target is therefore never a live claim — only a crash leftover, a corrupt link,
# or a stray inner link left when `ln -s` landed inside a leftover dir-form lock
# (the readlink-equals-$$ re-check catches that) — and is safe to break.
#
# Returns non-zero if the bounded retry cap is exhausted with a LIVE owner still
# holding it (stuck) — callers must then fail SAFE (never docker-rm under an
# uncertain lease state).
_lease_lock() {
  local lock="$LEASE_DIR.lock"
  local cap="${FISHHAWK_TEST_LEASE_LOCK_CAP:-50}"
  local tries=0 owner
  # Atomic acquire: ln -s creates the lock with our PID as its target in one
  # syscall. The readlink-equals-$$ re-check rejects the case where ln "succeeded"
  # by landing a stray link inside a leftover dir-form lock (which the break
  # branch below then clears), so only a genuine atomic claim returns success.
  while ! { ln -s "$$" "$lock" 2>/dev/null && [ "$(readlink "$lock" 2>/dev/null)" = "$$" ]; }; do
    owner="$(readlink "$lock" 2>/dev/null || true)"
    case "$owner" in
      ''|*[!0-9]*)
        # No/garbage owner target: NOT a live-holder claim (a live acquire always
        # carries its PID atomically). A crash leftover, corrupt link, or stray
        # inner link from an older dir-form lock — break it and retry.
        rm -rf "$lock" 2>/dev/null || true
        ;;
      *)
        if ! kill -0 "$owner" 2>/dev/null; then
          rm -f "$lock" 2>/dev/null || true  # dead owner → break the stale lock
        fi
        ;;
    esac
    tries=$((tries + 1))
    if [ "$tries" -ge "$cap" ]; then
      return 1
    fi
    sleep 0.1
  done
  return 0
}

_lease_unlock() {
  rm -rf "$LEASE_DIR.lock" 2>/dev/null || true
}

# _prune_dead_leases: drop lease files whose PID name no longer names a live
# process — crashed-invocation cleanup so a SIGKILL'd run never pins the
# container. Guards the empty glob and skips non-numeric names. Callers hold the
# lock.
_prune_dead_leases() {
  [ -d "$LEASE_DIR" ] || return 0
  local f base
  for f in "$LEASE_DIR"/*; do
    [ -e "$f" ] || continue  # empty-glob guard
    base="$(basename "$f")"
    case "$base" in
      ''|*[!0-9]*) continue ;;  # non-PID lease name — can't liveness-check, leave it
    esac
    if ! kill -0 "$base" 2>/dev/null; then
      rm -f "$f" 2>/dev/null || true
    fi
  done
}

# _register_lease: record this invocation's lease under the lock. Returns
# non-zero when it did NOT record a lease — no Docker (nothing to refcount) or a
# live-but-stuck lock the retry cap could not acquire. The caller MUST treat a
# non-zero return as "hold no lease" and NOT arm the reap: an invocation that
# never recorded a lease must never docker-rm the shared container, or it could
# reap it out from under a peer whose lease it never got the lock to see (the
# register-timeout lifecycle hole).
_register_lease() {
  command -v docker >/dev/null 2>&1 || return 1
  _lease_lock || return 1  # lock stuck → hold NO lease; caller must NOT arm reap
  mkdir -p "$LEASE_DIR" 2>/dev/null || true
  _prune_dead_leases
  : > "$LEASE_DIR/$(_lease_token)" 2>/dev/null || true
  _lease_unlock
  return 0
}

# _arm_container_lease: register this invocation's lease and arm the reap trap
# ONLY if the lease was actually recorded. Replaces the bare EXIT trap at the top
# of cmd_test / cmd_coverage. If registration failed (no Docker, or a live-stuck
# lock), we hold no lease and deliberately do NOT arm the reap — the container is
# left for a lease-holding invocation to reap, never removed under an uncertain
# lease state.
_arm_container_lease() {
  if _register_lease; then
    trap _reap_shared_container EXIT
  fi
}

# _reap_shared_container: EXIT-trap teardown. Remove ONLY this invocation's lease
# and docker-rm the shared container only when no leases remain. Fails SAFE on an
# unacquirable lock (a live-but-stuck owner): skip docker rm and leave the
# container for the next invocation's attach-reuse, never removing it under an
# uncertain lease state. Guarded to be a no-op when Docker is absent and to never
# fail the run.
_reap_shared_container() {
  command -v docker >/dev/null 2>&1 || return 0
  if ! _lease_lock; then
    return 0  # lock stuck (live owner) → fail safe, leave the container
  fi
  rm -f "$LEASE_DIR/$(_lease_token)" 2>/dev/null || true
  _prune_dead_leases
  if rmdir "$LEASE_DIR" 2>/dev/null; then
    docker rm -f fishhawk-test-postgres >/dev/null 2>&1 || true
  fi
  _lease_unlock
  return 0
}

modules() {
  go work edit -json | jq -r '.Use[].DiskPath'
}

# Full-suite test-binary parallelism (#972, #1174). Historically every backend
# package started its OWN testcontainers Postgres, so at the default -p
# (~GOMAXPROCS) a developer-Mac Docker daemon intermittently timed out starting
# one ("context deadline exceeded" after 9 retries against docker.sock) — pure
# load contention, not a real bug — and the bound was lowered 4 -> 2 to halve
# concurrent container starts.
#
# As of #1174 the backend integration tests share a SINGLE Postgres container
# (internal/pgtest): the first package to need it starts fishhawk-test-postgres,
# every other package attaches to it by name (testcontainers WithReuseByName),
# and each test gets a cheap per-test database cloned from a migrated template.
# There is no longer a container start per package, so the start-contention that
# forced -p 2 is gone — concurrent first-starts converge to the one shared
# container via pgtest's bounded attach-retry on the docker name conflict.
# Restored 2 -> 4 (#1174), proven by a full -p 4 run showing exactly one
# fishhawk-test-postgres via `docker ps`. `go test -p n` still caps concurrent
# test binaries; lower it on a constrained daemon with FISHHAWK_TEST_P (e.g.
# FISHHAWK_TEST_P=2). `single` runs are unbounded.
TEST_P="${FISHHAWK_TEST_P:-4}"

cmd_test() {
  _arm_container_lease
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && go test -race -p "$TEST_P" ./...)
  done < <(modules)
}

cmd_coverage() {
  _arm_container_lease
  local profiles=()
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && go test -race -p "$TEST_P" -coverprofile=coverage.out -covermode=atomic ./...)
    profiles+=("$m/coverage.out")
  done < <(modules)
  python3 "$ROOT/scripts/check-coverage.py" --threshold 80 --exclude '/db/' "${profiles[@]}"
}

# Fail CLOSED if golangci-lint is missing: the verify gate must never silently
# skip lint and re-open the gofmt/lint-drift-to-CI gap (#1064). Name the v2.x
# install pin (the v2.8.0 install.sh tag CI uses, per AGENTS.md / ci.yml) so the
# error is actionable. A v1 binary rejects this repo's v2-format .golangci.yml,
# so v2.x is required.
_require_golangci_lint() {
  if ! command -v golangci-lint >/dev/null 2>&1; then
    cat >&2 <<'EOF'
scripts/test: golangci-lint not found on PATH (required for `lint`/`verify`).
Install golangci-lint v2.x (this repo's .golangci.yml is v2-format; v1 rejects it):
  curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/v2.8.0/install.sh \
    | sh -s -- -b "$(go env GOPATH)/bin" v2.8.0
EOF
    exit 1
  fi
}

cmd_lint() {
  _require_golangci_lint
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && golangci-lint run ./...)
  done < <(modules)
}

# _verify_schema_sync: mirror CI's 'Schema sync (docs/spec ↔ embedded copies)'
# step (ci.yml) inside the verify gate so an implement pass that edits a
# canonical docs/spec/ file (or a mirrored default/preset) WITHOUT running
# scripts/sync-schemas fails IN-LOOP with CI's exact actionable message, instead
# of passing verify and then red-lining the required CI Pass check after the
# agent is terminal (#1064/#1772).
#
# Unlike CI's unscoped `git diff --exit-code`, this snapshots
# `git status --porcelain` before and after running sync-schemas and fails only
# if the porcelain output CHANGED — so a developer running verify on a dirty tree
# fails only on drift sync-schemas itself introduces, not on unrelated pending
# edits. On the runner's committed (clean) run-branch tree the two forms are
# equivalent. sync-schemas is a pure cp-only file mirror (set -eu), so an
# already-synced tree is a no-op that leaves the porcelain output unchanged.
#
# Guarded to a no-op (return 0, one-line stderr warning) when git is absent or
# $ROOT is not a git work tree — the check needs git to diff, and the runner
# always runs verify inside the committed worktree so the real path fires there.
_verify_schema_sync() {
  if ! command -v git >/dev/null 2>&1; then
    echo "scripts/test: git not found — skipping schema-sync drift check" >&2
    return 0
  fi
  # `--is-inside-work-tree` prints `true`/`false` and, in a BARE repo, prints
  # `false` yet exits 0 — so guard on the printed value, not just the exit
  # status, or a bare-repo $ROOT falls through to `git status --porcelain`
  # (which errors in a bare repo) instead of the documented return-0 no-op.
  if [ "$(git -C "$ROOT" rev-parse --is-inside-work-tree 2>/dev/null)" != "true" ]; then
    echo "scripts/test: $ROOT is not a git work tree — skipping schema-sync drift check" >&2
    return 0
  fi
  local before after
  before="$(git -C "$ROOT" status --porcelain)"
  "$ROOT/scripts/sync-schemas" >/dev/null
  after="$(git -C "$ROOT" status --porcelain)"
  if [ "$before" != "$after" ]; then
    echo "Embedded schema copies drifted from docs/spec/. Run scripts/sync-schemas and commit the result." >&2
    exit 1
  fi
}

# verify: the runner's committed-tree implement gate. Lint FIRST so a fast
# format/lint failure leads the captured output and aborts (set -e) before the
# slow test loop. Schema-sync drift is checked NEXT (a <1s file-copy + porcelain
# diff) so a docs/spec edit without a sync fails in-loop, still ahead of the slow
# test loop. Coverage is intentionally omitted to bound in-loop runtime — it
# stays on `coverage` and in CI.
cmd_verify() {
  cmd_lint
  _verify_schema_sync
  cmd_test
}

cmd_single() {
  if [ "$#" -eq 0 ]; then
    cat >&2 <<'EOF'
usage: scripts/test single <args>
example: scripts/test single -run TestNotifyPlanReady ./backend/internal/issuecomment/...
EOF
    exit 1
  fi
  go test -race "$@"
}

usage() {
  cat <<'EOF'
usage: scripts/test [SUBCOMMAND] [ARGS]

  test                 (default) run `go test -race ./...` in every module
  coverage             run tests + aggregate coverage gate
  lint                 run `golangci-lint run ./...` in every module
  verify               lint + schema-sync + tests (no coverage) — the runner's verify gate
  single ARGS          pass-through to `go test -race ARGS`
  -h | --help | help   show this message
EOF
}

# Bottom dispatch is skipped when sourced lib-only (FISHHAWK_TEST_LIB_ONLY=1),
# so scripts/test-container-lease can exercise the lease helpers without running
# a subcommand. Behavior is unchanged when the var is unset.
if [ -z "${FISHHAWK_TEST_LIB_ONLY:-}" ]; then
  case "${1:-test}" in
    test|"")          cmd_test ;;
    coverage|cover)   cmd_coverage ;;
    lint)             cmd_lint ;;
    verify)           cmd_verify ;;
    single)           shift; cmd_single "$@" ;;
    -h|--help|help)   usage ;;
    *)
      echo "scripts/test: unknown subcommand: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
fi
