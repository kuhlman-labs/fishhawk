#!/usr/bin/env bash
# scripts/test — wraps the multi-module Go test + coverage gates.
#
# Mirrors the loop CI uses for the Go lane: reads registered modules
# from go.work, runs each module's tests in its own directory.
# Fail-fast on the first module whose tests fail.
#
# Usage:
#   scripts/test              run `go test -race ./...` in every module
#   scripts/test coverage     the gate above + scripts/check-coverage.py
#   scripts/test lint         run `golangci-lint run ./...` in every module
#   scripts/test verify       lint + tests (no coverage) — the runner's gate
#   scripts/test single ARGS  pass-through to `go test -race ARGS`
#                             example:
#                             scripts/test single -run TestX ./backend/internal/version/...
#
# Frontend gates (pnpm format:check / typecheck / test) are NOT
# covered here — they have their own conventions per docs/.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Signing-agnostic isolation (#912): make every test that creates a temp repo
# and commits ignore the operator's global/system git config. Otherwise a
# global commit.gpgsign=true is inherited and red-lines the verify gate when
# the external signing agent (e.g. 1Password op-ssh-sign) is unavailable.
# Exported once here, so go test and its exec.Command("git", ...) children
# inherit it via os.Environ(). In-repo git ops are unaffected: the repo-local
# .git/config commit.gpgsign=false takes precedence over the now-absent global.
export GIT_CONFIG_GLOBAL=/dev/null
export GIT_CONFIG_SYSTEM=/dev/null

modules() {
  go work edit -json | jq -r '.Use[].DiskPath'
}

# Full-suite runs bound test-binary parallelism (#972): ~16 backend packages
# start a testcontainers Postgres each, and at the default -p (~GOMAXPROCS) a
# developer-Mac Docker daemon intermittently times out starting one
# ("context deadline exceeded" after 9 retries against docker.sock), failing
# the suite on load contention rather than a real bug. `go test -p n` caps how
# many test binaries run concurrently (tests within one binary are serial
# unless they call t.Parallel()), so this caps concurrent container starts.
# Modules run sequentially below, making the bound effectively global.
# Operator override: FISHHAWK_TEST_P. `single` runs are left unbounded.
TEST_P="${FISHHAWK_TEST_P:-4}"

cmd_test() {
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && go test -race -p "$TEST_P" ./...)
  done < <(modules)
}

cmd_coverage() {
  local profiles=()
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && go test -race -p "$TEST_P" -coverprofile=coverage.out -covermode=atomic ./...)
    profiles+=("$m/coverage.out")
  done < <(modules)
  python3 "$ROOT/scripts/check-coverage.py" --threshold 80 --exclude '/db/' "${profiles[@]}"
}

# Fail CLOSED if golangci-lint is missing: the verify gate must never silently
# skip lint and re-open the gofmt/lint-drift-to-CI gap (#1064). Name the v2.x
# install pin (the v2.8.0 install.sh tag CI uses, per AGENTS.md / ci.yml) so the
# error is actionable. A v1 binary rejects this repo's v2-format .golangci.yml,
# so v2.x is required.
_require_golangci_lint() {
  if ! command -v golangci-lint >/dev/null 2>&1; then
    cat >&2 <<'EOF'
scripts/test: golangci-lint not found on PATH (required for `lint`/`verify`).
Install golangci-lint v2.x (this repo's .golangci.yml is v2-format; v1 rejects it):
  curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/v2.8.0/install.sh \
    | sh -s -- -b "$(go env GOPATH)/bin" v2.8.0
EOF
    exit 1
  fi
}

cmd_lint() {
  _require_golangci_lint
  while IFS= read -r m; do
    printf '>>> %s\n' "$m"
    (cd "$m" && golangci-lint run ./...)
  done < <(modules)
}

# verify: the runner's committed-tree implement gate. Lint FIRST so a fast
# format/lint failure leads the captured output and aborts (set -e) before the
# slow test loop. Coverage is intentionally omitted to bound in-loop runtime —
# it stays on `coverage` and in CI.
cmd_verify() {
  cmd_lint
  cmd_test
}

cmd_single() {
  if [ "$#" -eq 0 ]; then
    cat >&2 <<'EOF'
usage: scripts/test single <args>
example: scripts/test single -run TestNotifyPlanReady ./backend/internal/issuecomment/...
EOF
    exit 1
  fi
  go test -race "$@"
}

usage() {
  cat <<'EOF'
usage: scripts/test [SUBCOMMAND] [ARGS]

  test                 (default) run `go test -race ./...` in every module
  coverage             run tests + aggregate coverage gate
  lint                 run `golangci-lint run ./...` in every module
  verify               lint + tests (no coverage) — the runner's verify gate
  single ARGS          pass-through to `go test -race ARGS`
  -h | --help | help   show this message
EOF
}

case "${1:-test}" in
  test|"")          cmd_test ;;
  coverage|cover)   cmd_coverage ;;
  lint)             cmd_lint ;;
  verify)           cmd_verify ;;
  single)           shift; cmd_single "$@" ;;
  -h|--help|help)   usage ;;
  *)
    echo "scripts/test: unknown subcommand: $1" >&2
    usage >&2
    exit 1
    ;;
esac
