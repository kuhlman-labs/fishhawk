# State backend configuration. Copy to backend.tf and fill in the
# values from the bootstrap step in README.md before the first
# `terraform init`.
#
# Reasoning is in ADR-016 (#165) — Terraform state lives in S3 with
# a DynamoDB table for distributed locks. The bucket + table are
# created out-of-band by the operator (chicken-and-egg of "the
# state store stores its own state").
#
# Per-environment bootstrap creates one bucket prefix per env:
#   s3://fishhawk-tfstate-<account-id>/<env>/terraform.tfstate
#
# The DynamoDB lock table is shared across environments — the lock
# key is derived from the bucket + key, so concurrent applies
# against different envs don't contend.
#
# terraform {
#   backend "s3" {
#     bucket         = "fishhawk-tfstate-<account-id>"
#     key            = "<env>/terraform.tfstate"
#     region         = "us-east-1"
#     dynamodb_table = "fishhawk-tfstate-lock"
#     encrypt        = true
#   }
# }
