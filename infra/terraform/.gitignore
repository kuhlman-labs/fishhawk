# Local state files (we use the S3 backend in real envs; the
# default-local backend is the dev fallback). Never commit either.
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
crash.log

# Per-environment variable files carry account IDs, OAuth client IDs,
# etc. — values are not secrets, but they're per-account and don't
# belong in git. Use prod.tfvars.example as the template.
*.tfvars
!*.tfvars.example

# Operator-supplied per-env backend configs (e.g. backend.dev.hcl,
# backend.prod.hcl) for local-machine plans. CI passes the same
# values via `-backend-config=...` from GitHub-environment
# variables; the committed `backend.tf` is the partial-config
# stub that both flows initialize against.
backend.*.hcl
